# ── App ─────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ── Database (PostgreSQL 16+) ───────────────────────────────────────
DATABASE_URL=postgres://smis:smis@localhost:5433/smis

# ── Redis (cache + BullMQ queues) ───────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT (Module 02 consumes; validated from day one) ────────────────
# Generate with: openssl rand -hex 32
JWT_ACCESS_SECRET=change-me-to-a-64-char-hex-string-change-me-change-me-change
JWT_REFRESH_SECRET=change-me-to-a-different-64-char-hex-string-change-me-change

# ── S3-compatible storage (MinIO in dev) ────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_DEFAULT=smis
S3_FORCE_PATH_STYLE=true

# ── SMTP (Mailpit in dev — UI at http://localhost:8025) ─────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM="HexSchool <no-reply@hexschool.local>"

# ── Security ────────────────────────────────────────────────────────
# Comma-separated origin whitelist
CORS_ORIGINS=http://localhost:3000
# Exactly 32 characters (AES-256 key)
SETTINGS_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef
RATE_LIMIT_TTL_MS=60000
RATE_LIMIT_MAX=100

# ── Ops dashboards (Bull Board always; Swagger basic-auth in prod) ──
ADMIN_DASH_USER=admin
ADMIN_DASH_PASS=change-me-8+

# ── Build metadata (injected by CI/Docker) ──────────────────────────
BUILD_SHA=dev
BUILD_TIME=
