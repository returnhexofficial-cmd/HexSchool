  OTHER

  @@map("gender_enum")
}

enum EmploymentType {
  PERMANENT
  CONTRACT
  PART_TIME

  @@map("employment_type_enum")
}

enum StaffStatus {
  ACTIVE
  ON_LEAVE
  RESIGNED
  TERMINATED
  RETIRED

  @@map("staff_status_enum")
}

enum StaffDocumentType {
  NID
  CERTIFICATE
  CV
  PHOTO
  CONTRACT
  OTHER

  @@map("staff_document_type_enum")
}

enum TeacherDesignation {
  HEAD_TEACHER
  ASSISTANT_HEAD
  SENIOR_TEACHER
  ASSISTANT_TEACHER
  SUBJECT_TEACHER
  PART_TIME

  @@map("teacher_designation_enum")
}

/// Interim leave taxonomy (M08); migrates into the HR leave system (M21).
enum LeaveType {
  CASUAL
  SICK
  MATERNITY
  UNPAID
  OTHER

  @@map("leave_type_enum")
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED

  @@map("leave_status_enum")
}

enum SessionStatus {
  UPCOMING
