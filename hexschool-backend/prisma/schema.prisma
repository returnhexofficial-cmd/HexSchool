  SUSPENDED

  @@map("school_status_enum")
}

enum SettingsGroup {
  general
  academic
  sms
  email
  payment
  attendance
  exam
  fees

  @@map("settings_group_enum")
}

enum SubjectType {
  THEORY
  PRACTICAL
  BOTH

  @@map("subject_type_enum")
}

enum StaffDesignation {
  PRINCIPAL
  VICE_PRINCIPAL
  ACCOUNTANT
  ADMISSION_OFFICER
  LIBRARIAN
  OFFICE_STAFF
  LAB_ASSISTANT
  SECURITY
  CLEANER
  OTHER

