  COMPLETED
  ARCHIVED

  @@map("session_status_enum")
}

enum HolidayType {
  GOVERNMENT
  RELIGIOUS
  SCHOOL
  WEEKLY

  @@map("holiday_type_enum")
}

enum HolidayAppliesTo {
  ALL
  STUDENTS
  STAFF

  @@map("holiday_applies_to_enum")
}

enum CalendarEventType {
  EXAM
  EVENT
  MEETING
