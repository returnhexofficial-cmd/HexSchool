  EMAIL_VERIFY
  ADMISSION

  @@map("otp_purpose_enum")
}

enum LoginEvent {
  LOGIN_SUCCESS
  LOGIN_FAILED
  LOGOUT
  REFRESH
  PASSWORD_CHANGED
  LOCKED
  TOKEN_REUSE

  @@map("login_event_enum")
}

enum SchoolType {
  PRIMARY
  HIGH_SCHOOL
  KINDERGARTEN
  ENGLISH_VERSION
  ENGLISH_MEDIUM
  MADRASA
  VOCATIONAL
  COLLEGE

