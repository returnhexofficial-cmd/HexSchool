}

enum AdmissionApplicationStatus {
  DRAFT
  SUBMITTED
  PAYMENT_PENDING
  UNDER_REVIEW
  TEST_SCHEDULED
  PASSED
  FAILED
  SELECTED
  WAITLISTED
  ADMITTED
  REJECTED
  CANCELLED
  EXPIRED

  @@map("admission_application_status_enum")
}

enum AdmissionPaymentStatus {
  UNPAID
  PAID
  WAIVED
  REFUNDED

  @@map("admission_payment_status_enum")
}

enum EnrollmentType {
  NEW
  PROMOTED
  READMITTED
  TRANSFERRED_IN

  @@map("enrollment_type_enum")
}

enum EnrollmentStatus {
  ACTIVE
  TRANSFERRED_OUT
  PROMOTED
  RETAINED
  COMPLETED
  CANCELLED

  @@map("enrollment_status_enum")
}

enum PromotionBatchStatus {
  DRAFT
  EXECUTED
  ROLLED_BACK

  @@map("promotion_batch_status_enum")
}

enum PromotionDecision {
  PROMOTE
  RETAIN
  GRADUATE
  EXCLUDE

  @@map("promotion_decision_enum")
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  LEAVE
  HALF_DAY
  HOLIDAY

  @@map("attendance_status_enum")
}

enum AttendanceMethod {
  MANUAL
  QR
  IMPORT
  AUTO

  @@map("attendance_method_enum")
}

/// staff_attendances is polymorphic over the two employee tables
/// (teachers / staff_profiles) — person_type says which one person_id
/// points at (no FK, like the audit tables).
enum AttendancePersonType {
  TEACHER
  STAFF

  @@map("attendance_person_type_enum")
}

enum StudentLeaveAppliedBy {
  GUARDIAN
  ADMIN

  @@map("student_leave_applied_by_enum")
}

/// What a period slot is used for. Only CLASS slots may hold a routine
/// entry (roadmap M13 §6) — BREAK/ASSEMBLY exist so the printed grid has
/// the real day shape and so attendance never targets a tiffin break.
enum PeriodSlotType {
  CLASS
  BREAK
  ASSEMBLY

  @@map("period_slot_type_enum")
}

/// Routine days. Saturday-first because the Bangladeshi school week runs
/// SAT→THU with Friday the standard weekly holiday; which days are
/// actually offered is filtered by `general.weekly_holidays` (M04).
enum Weekday {
  SAT
  SUN
  MON
  TUE
  WED
  THU
  FRI

  @@map("weekday_enum")
}

/// A routine version's lifecycle. Publishing promotes the DRAFT and
/// ARCHIVEs the timetable it replaces — old versions stay readable so a
/// past date's routine can still be reconstructed (roadmap M13 §6).
enum TimetableStatus {
  DRAFT
  PUBLISHED
  ARCHIVED

  @@map("timetable_status_enum")
}

/// An exam's lifecycle (roadmap M14 §3). The order is the transition
/// order: each state may only advance to the next one (or be ARCHIVEd),
/// which is what makes the status machine a straight line rather than a
/// graph. MARK_ENTRY is guarded by the exam's own end_date, and
/// PUBLISHED is gated by the Module 15 result processor.
enum ExamStatus {
  DRAFT
  SCHEDULED
  ONGOING
  MARK_ENTRY
  PROCESSING
  PUBLISHED
  ARCHIVED

  @@map("exam_status_enum")
}

/// How the seat-plan generator lays candidates into rooms (roadmap M14
/// §4). SERPENTINE keeps a class together and snakes roll order across
/// rooms; INTERLEAVE round-robins the attached classes so no two
/// neighbours sit the same paper (the anti-cheating layout).
enum SeatPlanStrategy {
  SERPENTINE
  INTERLEAVE

  @@map("seat_plan_strategy_enum")
}

/// A mark's place in the four-eyes lifecycle (roadmap M15 §3). The
/// subject teacher enters and SUBMITs, a controller/head VERIFIes, and
/// LOCKED is the point of no return — a locked mark changes only through
/// the correction flow (`marks.correction` + a reason, logged).
enum MarkStatus {
  DRAFT
  SUBMITTED
  VERIFIED
  LOCKED

  @@map("mark_status_enum")
}

/// The verdict on a student's whole exam. INCOMPLETE is the honest
/// answer for someone whose papers are not all marked (a mid-exam
/// transfer, or a processing run forced with `override`); WITHHELD is a
/// deliberate administrative act that hides the result everywhere.
enum ResultStatus {
  PASSED
  FAILED
  INCOMPLETE
  WITHHELD

  @@map("result_status_enum")
}

/// Lifecycle of one processing run. Durable in Postgres rather than in
/// BullMQ so `GET /process/status` keeps answering after a Redis restart
/// and so the run history survives the queue's retention window.
enum ResultRunStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED

  @@map("result_run_status_enum")
}

// ── Module 02: Authentication ─────────────────────────────────────────

/// Central account record for every human in the system. Role-specific
/// profile tables (Modules 07–09) link back 1:1. Uniqueness of email/phone
/// is enforced by partial unique indexes (WHERE deleted_at IS NULL) plus
/// chk_users_contact (email OR phone) — see the migration SQL.
/// school_id has no FK until Module 04 creates `schools`.
model User {
  id                  String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId            String     @map("school_id") @db.Uuid
  school              School     @relation(fields: [schoolId], references: [id], map: "fk_users_school")
  email               String?    @db.Citext
  phone               String?    @db.VarChar(15)
  passwordHash        String     @map("password_hash")
  userType            UserType   @map("user_type")
  status              UserStatus @default(ACTIVE)
  lastLoginAt         DateTime?  @map("last_login_at") @db.Timestamptz(6)
  passwordChangedAt   DateTime?  @map("password_changed_at") @db.Timestamptz(6)
  failedLoginAttempts Int        @default(0) @map("failed_login_attempts")
  lockedUntil         DateTime?  @map("locked_until") @db.Timestamptz(6)
  mustChangePassword  Boolean    @default(false) @map("must_change_password")

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  refreshTokens   RefreshToken[]
  otpCodes        OtpCode[]
  loginActivities LoginActivity[]
  userRoles       UserRole[]
  staffProfile    StaffProfile?
  teacher         Teacher?
  student         Student?
  guardian        Guardian?

  @@map("users")
}

/// One row per issued refresh token (multi-device sessions). Only the
/// SHA-256 hash is stored — the plaintext lives in the httpOnly cookie.
/// Rotation links old → new via replaced_by_id; a revoked token presented
/// again outside the race-grace window means theft. Purged nightly.
model RefreshToken {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade, map: "fk_refresh_tokens_user")
  tokenHash    String    @unique(map: "uq_refresh_tokens_token_hash") @map("token_hash") @db.VarChar(64)
  deviceInfo   Json      @default("{}") @map("device_info")
  expiresAt    DateTime  @map("expires_at") @db.Timestamptz(6)
  revokedAt    DateTime? @map("revoked_at") @db.Timestamptz(6)
  replacedById String?   @map("replaced_by_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([userId], map: "idx_refresh_tokens_user_id")
  @@map("refresh_tokens")
}

/// Hashed one-time codes (password reset, verification, admission…).
/// user_id is nullable: admission applicants (Module 10) verify phones
/// before having an account. Limits enforced in OtpService.
model OtpCode {
  id         String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String?    @map("user_id") @db.Uuid
  user       User?      @relation(fields: [userId], references: [id], onDelete: SetNull, map: "fk_otp_codes_user")
  identifier String
  codeHash   String     @map("code_hash") @db.VarChar(64)
  purpose    OtpPurpose
  expiresAt  DateTime   @map("expires_at") @db.Timestamptz(6)
  consumedAt DateTime?  @map("consumed_at") @db.Timestamptz(6)
  attempts   Int        @default(0)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([identifier, purpose, createdAt], map: "idx_otp_codes_identifier")
  @@map("otp_codes")
}

// ── Module 04: School Setup & Settings ────────────────────────────────

/// The tenant root — every business table's school_id points here since
/// M04 (users/roles carried the column FK-less from M02/03; this module
/// adds the constraints). Single row today; Module 31 turns this into
/// the multi-school catalog. The migration inserts the bootstrap row
/// with the fixed DEFAULT_SCHOOL_ID before wiring the FKs.
model School {
  id              String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String       @db.VarChar(200)
  nameBn          String?      @map("name_bn") @db.VarChar(200)
  /// Short unique code used in generated document numbers (M07+).
  code            String       @db.VarChar(10)
  /// BD Education Board EIIN (6 digits) — nullable for kindergartens etc.
  eiinNumber      String?      @map("eiin_number") @db.VarChar(6)
  type            SchoolType   @default(HIGH_SCHOOL)
  address         String?
  phone           String?      @db.VarChar(20)
  email           String?      @db.Citext
  website         String?      @db.VarChar(200)
  logoUrl         String?      @map("logo_url") @db.VarChar(500)
  establishedYear Int?         @map("established_year")
  principalName   String?      @map("principal_name") @db.VarChar(120)
  status          SchoolStatus @default(ACTIVE)

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  users                    User[]
  roles                    Role[]
  settings                 SchoolSetting[]
  gradingSystems           GradingSystem[]
  academicSessions         AcademicSession[]
  departments              Department[]
  shifts                   Shift[]
  classes                  SchoolClass[]
  groups                   Group[]
  sections                 Section[]
  subjects                 Subject[]
  classSubjects            ClassSubject[]
  staffProfiles            StaffProfile[]
  staffDocuments           StaffDocument[]
  teachers                 Teacher[]
  teacherSectionSubjects   TeacherSectionSubject[]
  teacherLeaves            TeacherLeave[]
  teacherEvaluations       TeacherEvaluation[]
  teacherDocuments         TeacherDocument[]
  students                 Student[]
  guardians                Guardian[]
  studentMedicalInfos      StudentMedicalInfo[]
  studentDocuments         StudentDocument[]
  admissionCycles          AdmissionCycle[]
  enrollments              Enrollment[]
  promotionBatches         PromotionBatch[]
  studentAttendances       StudentAttendance[]
  staffAttendances         StaffAttendance[]
  studentLeaveApplications StudentLeaveApplication[]
  periodSlots              PeriodSlot[]
  timetables               Timetable[]
  timetableEntries         TimetableEntry[]
  examTypes                ExamType[]
  exams                    Exam[]
  examSubjects             ExamSubject[]
  seatPlans                SeatPlan[]
  seatPlanEntries          SeatPlanEntry[]
  marks                    Mark[]
  markCorrections          MarkCorrection[]
  results                  Result[]
  resultPublications       ResultPublication[]
  resultRuns               ResultRun[]
  combinedResults          CombinedResult[]

  @@map("schools")
}

/// Generic key-value configuration, one row per key. Keys/types/secrecy
/// are declared in the TS settings registry (settings.registry.ts);
/// secret values are AES-256-GCM encrypted before they land here.
model SchoolSetting {
  id       String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId String        @map("school_id") @db.Uuid
  school   School        @relation(fields: [schoolId], references: [id], onDelete: Cascade, map: "fk_school_settings_school")
  key      String        @db.VarChar(100)
  value    Json
  group    SettingsGroup

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  updatedBy String?  @map("updated_by") @db.Uuid

  @@unique([schoolId, key], map: "uq_school_settings_key")
  @@index([schoolId, group], map: "idx_school_settings_group")
  @@map("school_settings")
}

/// Grade scale container. Exactly one default per school (partial unique
/// index, hand-written); a system may only become default once its grade
/// ranges cover 0–100 with no gaps/overlaps (service-enforced).
model GradingSystem {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId  String  @map("school_id") @db.Uuid
  school    School  @relation(fields: [schoolId], references: [id], onDelete: Cascade, map: "fk_grading_systems_school")
  name      String  @db.VarChar(100)
  isDefault Boolean @default(false) @map("is_default")

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  gradePoints GradePoint[]
  exams       Exam[]

  @@index([schoolId], map: "idx_grading_systems_school")
  @@map("grading_systems")
}

/// One grade band (A+ 80–100 → 5.00). Child rows are replaced wholesale
/// with their system — no soft delete. Range sanity (min ≤ max) is a DB
/// CHECK; non-overlap is service-enforced.
model GradePoint {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gradingSystemId String        @map("grading_system_id") @db.Uuid
  gradingSystem   GradingSystem @relation(fields: [gradingSystemId], references: [id], onDelete: Cascade, map: "fk_grade_points_system")
  grade           String        @db.VarChar(5)
  point           Decimal       @db.Decimal(3, 2)
  minMark         Int           @map("min_mark")
  maxMark         Int           @map("max_mark")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([gradingSystemId, grade], map: "uq_grade_points_grade")
  @@map("grade_points")
}

// ── Module 05: Academic Session & Calendar ────────────────────────────

/// Academic year — the temporal backbone every enrollment/attendance/
/// exam/fee record scopes to (from M11 on). Exactly one is_current per
/// school (partial unique index, hand-written); date ranges of a
/// school's sessions never overlap (service-enforced); COMPLETED
/// sessions become read-only for entry flows (enforced by consumers).
model AcademicSession {
  id        String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId  String        @map("school_id") @db.Uuid
  school    School        @relation(fields: [schoolId], references: [id], map: "fk_academic_sessions_school")
  name      String        @db.VarChar(50)
  startDate DateTime      @map("start_date") @db.Date
  endDate   DateTime      @map("end_date") @db.Date
  status    SessionStatus @default(UPCOMING)
  isCurrent Boolean       @default(false) @map("is_current")

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  holidays                 Holiday[]
  calendarEvents           CalendarEvent[]
  sections                 Section[]
  classSubjects            ClassSubject[]
  teacherSectionSubjects   TeacherSectionSubject[]
  teacherEvaluations       TeacherEvaluation[]
  admissionCycles          AdmissionCycle[]
  enrollments              Enrollment[]
  promotionBatchesFrom     PromotionBatch[]          @relation("PromotionBatchFrom")
  promotionBatchesTo       PromotionBatch[]          @relation("PromotionBatchTo")
  studentLeaveApplications StudentLeaveApplication[]
  timetables               Timetable[]
  exams                    Exam[]
  combinedResults          CombinedResult[]

  @@index([schoolId], map: "idx_academic_sessions_school")
  @@map("academic_sessions")
}

/// Non-working day range. Hard-deleted (spec: audit only, no soft
/// delete) — cancelling a holiday removes it; the audit trail keeps the
/// history. WEEKLY rows are ad-hoc extras; the recurring weekly holiday
/// comes from the `general.weekly_holidays` setting (M04).
model Holiday {
  id        String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId  String           @map("school_id") @db.Uuid
  sessionId String           @map("session_id") @db.Uuid
  session   AcademicSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade, map: "fk_holidays_session")
  title     String           @db.VarChar(200)
  startDate DateTime         @map("start_date") @db.Date
  endDate   DateTime         @map("end_date") @db.Date
  type      HolidayType      @default(SCHOOL)
  appliesTo HolidayAppliesTo @default(ALL) @map("applies_to")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy String?  @map("created_by") @db.Uuid
  updatedBy String?  @map("updated_by") @db.Uuid

  @@index([schoolId, startDate, endDate], map: "idx_holidays_range")
  @@index([sessionId], map: "idx_holidays_session")
  @@map("holidays")
}

/// Calendar entry (exam window, meeting, sports day…). is_public rows
/// surface on the public website (M19).
model CalendarEvent {
  id          String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId    String            @map("school_id") @db.Uuid
  sessionId   String            @map("session_id") @db.Uuid
  session     AcademicSession   @relation(fields: [sessionId], references: [id], onDelete: Cascade, map: "fk_calendar_events_session")
  title       String            @db.VarChar(200)
  description String?
  startDate   DateTime          @map("start_date") @db.Date
  endDate     DateTime          @map("end_date") @db.Date
  type        CalendarEventType @default(EVENT)
  isPublic    Boolean           @default(false) @map("is_public")

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  @@index([schoolId, startDate, endDate], map: "idx_calendar_events_range")
  @@index([sessionId], map: "idx_calendar_events_session")
  @@map("calendar_events")
}

// ── Module 06: Academic Structure ─────────────────────────────────────

/// Organizational unit for staff (M07) and subjects.
model Department {
  id       String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId String @map("school_id") @db.Uuid
  school   School @relation(fields: [schoolId], references: [id], map: "fk_departments_school")
  name     String @db.VarChar(100)
  code     String @db.VarChar(20)

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  subjects      Subject[]
  staffProfiles StaffProfile[]
  teachers      Teacher[]

  @@index([schoolId], map: "idx_departments_school")
  @@map("departments")
}

/// School shift (Morning/Day). Rarely churns — hard-deleted (spec:
/// audit only), delete guarded while sections reference it.
model Shift {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId  String   @map("school_id") @db.Uuid
  school    School   @relation(fields: [schoolId], references: [id], map: "fk_shifts_school")
  name      String   @db.VarChar(50)
  startTime DateTime @map("start_time") @db.Time(0)
  endTime   DateTime @map("end_time") @db.Time(0)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy String?  @map("created_by") @db.Uuid
  updatedBy String?  @map("updated_by") @db.Uuid

  sections    Section[]
  enrollments Enrollment[]
  periodSlots PeriodSlot[]

  // Hand-written in the M06 migration; declared here too so drift
  // detection doesn't try to drop it (it's a plain unique index, which
  // Prisma CAN express — unlike the partial ones).
  @@unique([schoolId, name], map: "uq_shifts_name")
  @@index([schoolId], map: "idx_shifts_school")
  @@map("shifts")
}

/// Session-independent class master ("Class 6"). numeric_level drives
/// ordering and the group-applicability rule; free-form names support
/// Madrasa/Vocational naming (M06 §8). Model named SchoolClass because
/// `class` collides with the TS keyword in generated code.
model SchoolClass {
  id           String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId     String  @map("school_id") @db.Uuid
  school       School  @relation(fields: [schoolId], references: [id], map: "fk_classes_school")
  name         String  @db.VarChar(100)
  nameBn       String? @map("name_bn") @db.VarChar(100)
  numericLevel Int     @map("numeric_level")
  displayOrder Int     @default(0) @map("display_order")

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  sections              Section[]
  classSubjects         ClassSubject[]
  admittedStudents      Student[]
  admissionCycleClasses AdmissionCycleClass[]
  admissionApplications AdmissionApplication[]
  admissionTests        AdmissionTest[]
  enrollments           Enrollment[]
  promotionItemsTo      PromotionItem[]
  examClasses           ExamClass[]
  examSubjects          ExamSubject[]

  @@index([schoolId], map: "idx_classes_school")
  @@map("classes")
}

/// Academic stream (Science/Commerce/Arts/…). Applies only from a class
/// level (BD default: class 9) — enforced when a section/mapping uses it.
model Group {
  id                  String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId            String @map("school_id") @db.Uuid
  school              School @relation(fields: [schoolId], references: [id], map: "fk_groups_school")
  name                String @db.VarChar(50)
  applicableFromLevel Int    @default(9) @map("applicable_from_level")

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  sections      Section[]
  classSubjects ClassSubject[]
  enrollments   Enrollment[]

  @@index([schoolId], map: "idx_groups_school")
  @@map("groups")
}

/// Where a student sits: session-scoped (Class 6-A of 2026 ≠ 2027).
/// Identity uniqueness (school, session, class, name, shift) is a
/// hand-written COALESCE index (NULL shift must not evade it).
/// class_teacher_id has NO FK until Module 08 creates `teachers`.
model Section {
  id             String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId       String          @map("school_id") @db.Uuid
  school         School          @relation(fields: [schoolId], references: [id], map: "fk_sections_school")
  classId        String          @map("class_id") @db.Uuid
  class          SchoolClass     @relation(fields: [classId], references: [id], map: "fk_sections_class")
  sessionId      String          @map("session_id") @db.Uuid
  session        AcademicSession @relation(fields: [sessionId], references: [id], onDelete: Cascade, map: "fk_sections_session")
  name           String          @db.VarChar(5)
  shiftId        String?         @map("shift_id") @db.Uuid
  shift          Shift?          @relation(fields: [shiftId], references: [id], map: "fk_sections_shift")
  groupId        String?         @map("group_id") @db.Uuid
  group          Group?          @relation(fields: [groupId], references: [id], map: "fk_sections_group")
  /// Advisory at creation; enforced at enrollment (M11) with override.
  capacity       Int?
  /// FK added in M08 (deferred from M06 — teachers didn't exist yet).
  classTeacherId String?         @map("class_teacher_id") @db.Uuid
  classTeacher   Teacher?        @relation(fields: [classTeacherId], references: [id], map: "fk_sections_class_teacher")
  roomNo         String?         @map("room_no") @db.VarChar(20)

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  teacherSectionSubjects TeacherSectionSubject[]
  enrollments            Enrollment[]
  promotionItemsTo       PromotionItem[]
  studentAttendances     StudentAttendance[]
  timetables             Timetable[]
  combinedTimetableEntry TimetableEntry[]        @relation("TimetableEntryCombinedWith")

  @@index([schoolId, sessionId], map: "idx_sections_school_session")
  @@index([classId], map: "idx_sections_class")
  @@map("sections")
}

/// Session-independent subject master. THEORY/PRACTICAL split marks are
/// handled by `type` + exam mark distribution (M14), never duplicates.
model Subject {
  id           String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId     String      @map("school_id") @db.Uuid
  school       School      @relation(fields: [schoolId], references: [id], map: "fk_subjects_school")
  name         String      @db.VarChar(100)
  nameBn       String?     @map("name_bn") @db.VarChar(100)
  code         String      @db.VarChar(20)
  departmentId String?     @map("department_id") @db.Uuid
  department   Department? @relation(fields: [departmentId], references: [id], map: "fk_subjects_department")
  type         SubjectType @default(THEORY)

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  classSubjects          ClassSubject[]
  teacherSubjects        TeacherSubject[]
  teacherSectionSubjects TeacherSectionSubject[]
  optionalEnrollments    Enrollment[]            @relation("EnrollmentOptionalSubject")
  timetableEntries       TimetableEntry[]
  examSubjects           ExamSubject[]

  @@index([schoolId], map: "idx_subjects_school")
  @@map("subjects")
}

/// Curriculum mapping: what a class studies in a session (optionally per
/// group; is_optional marks the BD "4th subject"). Rows are replaced by
/// the bulk assign endpoint; removal is blocked once marks exist (M15
/// extends the guard). Identity uniqueness is a COALESCE index (NULL
/// group must not evade it).
model ClassSubject {
  id               String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId         String          @map("school_id") @db.Uuid
  school           School          @relation(fields: [schoolId], references: [id], map: "fk_class_subjects_school")
  classId          String          @map("class_id") @db.Uuid
  class            SchoolClass     @relation(fields: [classId], references: [id], map: "fk_class_subjects_class")
  subjectId        String          @map("subject_id") @db.Uuid
  subject          Subject         @relation(fields: [subjectId], references: [id], map: "fk_class_subjects_subject")
  sessionId        String          @map("session_id") @db.Uuid
  session          AcademicSession @relation(fields: [sessionId], references: [id], onDelete: Cascade, map: "fk_class_subjects_session")
  groupId          String?         @map("group_id") @db.Uuid
  group            Group?          @relation(fields: [groupId], references: [id], map: "fk_class_subjects_group")
  isOptional       Boolean         @default(false) @map("is_optional")
  fullMarksDefault Int             @default(100) @map("full_marks_default")
  displayOrder     Int             @default(0) @map("display_order")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([classId, sessionId], map: "idx_class_subjects_class_session")
  @@index([subjectId], map: "idx_class_subjects_subject")
  @@map("class_subjects")
}

// ── Module 07: Staff & User Management ────────────────────────────────

/// Non-teaching staff record, 1:1 with a User account (created
/// transactionally with a temp password). employee_id comes from the
/// gap-free per-school sequence service and is NEVER reused — the
/// employee-id unique index is deliberately NOT soft-delete-scoped.
model StaffProfile {
  id             String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId       String           @map("school_id") @db.Uuid
  school         School           @relation(fields: [schoolId], references: [id], map: "fk_staff_profiles_school")
  userId         String           @unique(map: "uq_staff_profiles_user") @map("user_id") @db.Uuid
  user           User             @relation(fields: [userId], references: [id], map: "fk_staff_profiles_user")
  employeeId     String           @map("employee_id") @db.VarChar(30)
  firstName      String           @map("first_name") @db.VarChar(100)
  lastName       String           @map("last_name") @db.VarChar(100)
  nameBn         String?          @map("name_bn") @db.VarChar(200)
  designation    StaffDesignation
  departmentId   String?          @map("department_id") @db.Uuid
  department     Department?      @relation(fields: [departmentId], references: [id], map: "fk_staff_profiles_department")
  gender         Gender
  dob            DateTime         @db.Date
  bloodGroup     String?          @map("blood_group") @db.VarChar(5)
  /// BD NID: 10/13/17 digits. Soft-checked for duplicates (data quality
  /// varies) — deliberately NOT unique.
  nidNumber      String?          @map("nid_number") @db.VarChar(17)
  /// S3 object key; signed URL minted on read.
  photoUrl       String?          @map("photo_url") @db.VarChar(500)
  /// { present: string, permanent: string }
  address        Json             @default("{}")
  joiningDate    DateTime         @map("joining_date") @db.Date
  employmentType EmploymentType   @default(PERMANENT) @map("employment_type")
  status         StaffStatus      @default(ACTIVE)

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  documents StaffDocument[]

  // Deliberately NOT deleted_at-scoped: employee IDs are never reused
  // (hand-written in the M07 migration; declared here so drift detection
  // leaves it alone — it's a plain unique, which Prisma CAN express).
  @@unique([schoolId, employeeId], map: "uq_staff_profiles_employee_id")
  @@index([schoolId, status], map: "idx_staff_profiles_school_status")
  @@index([departmentId], map: "idx_staff_profiles_department")
  @@map("staff_profiles")
}

/// Uploaded staff paperwork (NID scan, certificates, CV…). Hard-deleted
/// (delete removes the S3 object too); the audit trail keeps history —
/// same treatment as M05 holidays.
model StaffDocument {
  id         String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId   String            @map("school_id") @db.Uuid
  school     School            @relation(fields: [schoolId], references: [id], map: "fk_staff_documents_school")
  staffId    String            @map("staff_id") @db.Uuid
  staff      StaffProfile      @relation(fields: [staffId], references: [id], onDelete: Cascade, map: "fk_staff_documents_staff")
  title      String            @db.VarChar(200)
  type       StaffDocumentType @default(OTHER)
  /// S3 object key; signed URL minted on read.
  fileUrl    String            @map("file_url") @db.VarChar(500)
  mimeType   String            @map("mime_type") @db.VarChar(100)
  sizeBytes  Int               @map("size_bytes")
  uploadedBy String?           @map("uploaded_by") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([staffId], map: "idx_staff_documents_staff")
  @@map("staff_documents")
}

// ── Module 08: Teacher Management ─────────────────────────────────────

/// Teaching staff, 1:1 with a User (same transactional-creation pattern
/// as staff_profiles). DECISION (roadmap M08 §3): a SEPARATE table
/// sharing the user — not an extension of staff_profiles — duplicating
/// the personal columns; teacher-specific fields (salary grade, MPO
/// index, specialization) live here. Employee IDs come from the shared
/// SequenceService; like staff, the unique index ignores deleted_at.
model Teacher {
  id             String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId       String             @map("school_id") @db.Uuid
  school         School             @relation(fields: [schoolId], references: [id], map: "fk_teachers_school")
  userId         String             @unique(map: "uq_teachers_user") @map("user_id") @db.Uuid
  user           User               @relation(fields: [userId], references: [id], map: "fk_teachers_user")
  employeeId     String             @map("employee_id") @db.VarChar(30)
  firstName      String             @map("first_name") @db.VarChar(100)
  lastName       String             @map("last_name") @db.VarChar(100)
  nameBn         String?            @map("name_bn") @db.VarChar(200)
  designation    TeacherDesignation
  departmentId   String?            @map("department_id") @db.Uuid
  department     Department?        @relation(fields: [departmentId], references: [id], map: "fk_teachers_department")
  gender         Gender
  dob            DateTime           @db.Date
  bloodGroup     String?            @map("blood_group") @db.VarChar(5)
  nidNumber      String?            @map("nid_number") @db.VarChar(17)
  photoUrl       String?            @map("photo_url") @db.VarChar(500)
  address        Json               @default("{}")
  joiningDate    DateTime           @map("joining_date") @db.Date
  salaryGrade    String?            @map("salary_grade") @db.VarChar(30)
  /// BD Monthly Pay Order index (government-subsidized schools).
  mpoIndexNo     String?            @map("mpo_index_no") @db.VarChar(30)
  specialization String?            @db.VarChar(200)
  status         StaffStatus        @default(ACTIVE)

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  qualifications   TeacherQualification[]
  subjects         TeacherSubject[]
  assignments      TeacherSectionSubject[]
  leaves           TeacherLeave[]
  evaluations      TeacherEvaluation[]
  documents        TeacherDocument[]
  classTeacherOf   Section[]
  timetableEntries TimetableEntry[]

  // Same rule as staff: NOT deleted_at-scoped — teacher IDs never reused.
  @@unique([schoolId, employeeId], map: "uq_teachers_employee_id")
  @@index([schoolId, status], map: "idx_teachers_school_status")
  @@index([departmentId], map: "idx_teachers_department")
  @@map("teachers")
}

/// Academic degrees (SSC → PhD). document_url reserved for a scanned
/// certificate key; uploads go through teacher_documents for now.
model TeacherQualification {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  teacherId   String  @map("teacher_id") @db.Uuid
  teacher     Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade, map: "fk_teacher_qualifications_teacher")
  degree      String  @db.VarChar(100)
  institution String  @db.VarChar(200)
  passingYear Int     @map("passing_year")
  result      String? @db.VarChar(50)
  documentUrl String? @map("document_url") @db.VarChar(500)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy String?  @map("created_by") @db.Uuid
  updatedBy String?  @map("updated_by") @db.Uuid

  @@index([teacherId], map: "idx_teacher_qualifications_teacher")
  @@map("teacher_qualifications")
}

/// Subject expertise (join table — what a teacher CAN teach; the
/// assignment table below is what they DO teach where).
model TeacherSubject {
  teacherId String  @map("teacher_id") @db.Uuid
  teacher   Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade, map: "fk_teacher_subjects_teacher")
  subjectId String  @map("subject_id") @db.Uuid
  subject   Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade, map: "fk_teacher_subjects_subject")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@id([teacherId, subjectId], map: "pk_teacher_subjects")
  @@index([subjectId], map: "idx_teacher_subjects_subject")
  @@map("teacher_subjects")
}

/// Who teaches what where: one teacher per (session, section, subject) —
/// reassignment REPLACES the row (history lives in audit_logs). The
/// timetable conflict check hooks in with M13.
model TeacherSectionSubject {
  id        String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId  String          @map("school_id") @db.Uuid
  school    School          @relation(fields: [schoolId], references: [id], map: "fk_teacher_section_subjects_school")
  sessionId String          @map("session_id") @db.Uuid
  session   AcademicSession @relation(fields: [sessionId], references: [id], onDelete: Cascade, map: "fk_teacher_section_subjects_session")
  teacherId String          @map("teacher_id") @db.Uuid
  teacher   Teacher         @relation(fields: [teacherId], references: [id], map: "fk_teacher_section_subjects_teacher")
  sectionId String          @map("section_id") @db.Uuid
  section   Section         @relation(fields: [sectionId], references: [id], onDelete: Cascade, map: "fk_teacher_section_subjects_section")
  subjectId String          @map("subject_id") @db.Uuid
  subject   Subject         @relation(fields: [subjectId], references: [id], map: "fk_teacher_section_subjects_subject")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy String?  @map("created_by") @db.Uuid
  updatedBy String?  @map("updated_by") @db.Uuid

  @@unique([sessionId, sectionId, subjectId], map: "uq_teacher_assignments_slot")
  @@index([teacherId, sessionId], map: "idx_teacher_assignments_teacher")
  @@index([sectionId], map: "idx_teacher_assignments_section")
  @@map("teacher_section_subjects")
}

/// Minimal leave records (roadmap M08 §3) — PENDING rows may be hard-
/// deleted; APPROVED/REJECTED are kept. Designed to migrate into the HR
/// leave system (M21). Overlap of APPROVED ranges is service-enforced.
model TeacherLeave {
  id         String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId   String      @map("school_id") @db.Uuid
  school     School      @relation(fields: [schoolId], references: [id], map: "fk_teacher_leaves_school")
  teacherId  String      @map("teacher_id") @db.Uuid
  teacher    Teacher     @relation(fields: [teacherId], references: [id], onDelete: Cascade, map: "fk_teacher_leaves_teacher")
  fromDate   DateTime    @map("from_date") @db.Date
  toDate     DateTime    @map("to_date") @db.Date
  type       LeaveType   @default(CASUAL)
  status     LeaveStatus @default(PENDING)
  reason     String?
  approvedBy String?     @map("approved_by") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy String?  @map("created_by") @db.Uuid
  updatedBy String?  @map("updated_by") @db.Uuid

  @@index([teacherId, status], map: "idx_teacher_leaves_teacher_status")
  @@index([schoolId, fromDate, toDate], map: "idx_teacher_leaves_range")
  @@map("teacher_leaves")
}

/// Periodic evaluation: per-criterion scores in `criteria` (criterion →
/// 0–100), overall `score` 0–100. Criteria names come from the
/// `academic.teacher_evaluation_criteria` setting.
model TeacherEvaluation {
  id          String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId    String          @map("school_id") @db.Uuid
  school      School          @relation(fields: [schoolId], references: [id], map: "fk_teacher_evaluations_school")
  teacherId   String          @map("teacher_id") @db.Uuid
  teacher     Teacher         @relation(fields: [teacherId], references: [id], onDelete: Cascade, map: "fk_teacher_evaluations_teacher")
  sessionId   String          @map("session_id") @db.Uuid
  session     AcademicSession @relation(fields: [sessionId], references: [id], onDelete: Cascade, map: "fk_teacher_evaluations_session")
  evaluatorId String          @map("evaluator_id") @db.Uuid
  criteria    Json            @default("{}")
  score       Decimal         @db.Decimal(5, 2)
  remarks     String?
  evaluatedAt DateTime        @map("evaluated_at") @db.Date

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy String?  @map("created_by") @db.Uuid
  updatedBy String?  @map("updated_by") @db.Uuid

  @@index([teacherId, sessionId], map: "idx_teacher_evaluations_teacher")
  @@map("teacher_evaluations")
}

/// Teacher paperwork — mirrors staff_documents (hard-deleted with the
/// S3 object; audit keeps history). Shares staff_document_type_enum.
model TeacherDocument {
  id         String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId   String            @map("school_id") @db.Uuid
  school     School            @relation(fields: [schoolId], references: [id], map: "fk_teacher_documents_school")
  teacherId  String            @map("teacher_id") @db.Uuid
  teacher    Teacher           @relation(fields: [teacherId], references: [id], onDelete: Cascade, map: "fk_teacher_documents_teacher")
  title      String            @db.VarChar(200)
  type       StaffDocumentType @default(OTHER)
  fileUrl    String            @map("file_url") @db.VarChar(500)
  mimeType   String            @map("mime_type") @db.VarChar(100)
  sizeBytes  Int               @map("size_bytes")
  uploadedBy String?           @map("uploaded_by") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([teacherId], map: "idx_teacher_documents_teacher")
  @@map("teacher_documents")
}

// ── Module 09: Student & Guardian Management ──────────────────────────

/// The student master record (roadmap M09). `student_uid` is the
/// PERMANENT identity (never changes across sessions/classes; roll
/// numbers are enrollment-scoped, M11) — generated by SequenceService
/// from `general.student_id_pattern`; like employee IDs its unique index
/// deliberately IGNORES deleted_at (UIDs never reused). The portal user
/// account is created LAZILY (user_id NULL until provisioned). qr_token
/// is a random rotatable token printed on the ID card QR.
model Student {
  id                 String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId           String        @map("school_id") @db.Uuid
  school             School        @relation(fields: [schoolId], references: [id], map: "fk_students_school")
  userId             String?       @unique(map: "uq_students_user") @map("user_id") @db.Uuid
  user               User?         @relation(fields: [userId], references: [id], map: "fk_students_user")
  studentUid         String        @map("student_uid") @db.VarChar(30)
  firstName          String        @map("first_name") @db.VarChar(100)
  lastName           String        @map("last_name") @db.VarChar(100)
  nameBn             String?       @map("name_bn") @db.VarChar(200)
  gender             Gender
  dob                DateTime      @db.Date
  bloodGroup         String?       @map("blood_group") @db.VarChar(5)
  religion           Religion      @default(ISLAM)
  /// BD birth certificate: 17 digits. Soft-unique per school (partial
  /// unique index WHERE deleted_at IS NULL — hand-written).
  birthCertificateNo String?       @map("birth_certificate_no") @db.VarChar(17)
  /// S3 object key; signed URL minted on read.
  photoUrl           String?       @map("photo_url") @db.VarChar(500)
  presentAddress     Json          @default("{}") @map("present_address")
  permanentAddress   Json          @default("{}") @map("permanent_address")
  admissionDate      DateTime      @map("admission_date") @db.Date
  admissionClassId   String?       @map("admission_class_id") @db.Uuid
  admissionClass     SchoolClass?  @relation(fields: [admissionClassId], references: [id], map: "fk_students_admission_class")
  previousSchool     String?       @map("previous_school") @db.VarChar(300)
  status             StudentStatus @default(ACTIVE)
  /// Random rotatable token encoded in the ID-card QR (never the raw id).
  qrToken            String        @map("qr_token") @db.VarChar(64)

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  guardians             StudentGuardian[]
  medicalInfo           StudentMedicalInfo?
  documents             StudentDocument[]
  statusHistory         StudentStatusHistory[]
  admissionApplications AdmissionApplication[]
  enrollments           Enrollment[]
  promotionItems        PromotionItem[]
  leaveApplications     StudentLeaveApplication[]

  // Deliberately NOT deleted_at-scoped: student UIDs are never reused.
  @@unique([schoolId, studentUid], map: "uq_students_uid")
  @@unique([qrToken], map: "uq_students_qr_token")
  @@index([schoolId, status], map: "idx_students_school_status")
  @@index([schoolId, admissionClassId], map: "idx_students_admission_class")
  @@index([schoolId, dob], map: "idx_students_dob")
  @@map("students")
}

/// Guardian master — shared across siblings (dedup by phone at link
/// time). Becomes a PARENT portal user lazily, like students. `relation`
/// here is the guardian's own relation type; the per-student relation
/// lives on the student_guardians link (an aunt can be one child's
/// LEGAL_GUARDIAN and another's emergency contact).
model Guardian {
  id            String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId      String           @map("school_id") @db.Uuid
  school        School           @relation(fields: [schoolId], references: [id], map: "fk_guardians_school")
  userId        String?          @unique(map: "uq_guardians_user") @map("user_id") @db.Uuid
  user          User?            @relation(fields: [userId], references: [id], map: "fk_guardians_user")
  name          String           @db.VarChar(200)
  nameBn        String?          @map("name_bn") @db.VarChar(200)
  relation      GuardianRelation @default(OTHER)
  /// BD mobile, mandatory (roadmap M09 §7) — the default SMS target
  /// when this guardian is a student's primary.
  phone         String           @db.VarChar(15)
  email         String?          @db.Citext
  nid           String?          @db.VarChar(17)
  occupation    String?          @db.VarChar(120)
  monthlyIncome Decimal?         @map("monthly_income") @db.Decimal(12, 2)
  address       Json             @default("{}")

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  students StudentGuardian[]

  @@index([schoolId, phone], map: "idx_guardians_school_phone")
  @@map("guardians")
}

/// Student ↔ guardian link (M:N — siblings share guardian rows). One
/// primary per student is a hand-written partial unique index
/// (uq_student_guardians_primary WHERE is_primary).
model StudentGuardian {
  studentId          String           @map("student_id") @db.Uuid
  student            Student          @relation(fields: [studentId], references: [id], onDelete: Cascade, map: "fk_student_guardians_student")
  guardianId         String           @map("guardian_id") @db.Uuid
  guardian           Guardian         @relation(fields: [guardianId], references: [id], onDelete: Cascade, map: "fk_student_guardians_guardian")
  relation           GuardianRelation @default(OTHER)
  isPrimary          Boolean          @default(false) @map("is_primary")
  isEmergencyContact Boolean          @default(false) @map("is_emergency_contact")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@id([studentId, guardianId], map: "pk_student_guardians")
  @@index([guardianId], map: "idx_student_guardians_guardian")
  @@map("student_guardians")
}

/// Health record, 1:1 with the student. Access restricted to the
/// `student.medical.view` / `student.medical.update` permissions and
/// NEVER included in exports by default (roadmap M09 §6).
model StudentMedicalInfo {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId          String   @map("school_id") @db.Uuid
  school            School   @relation(fields: [schoolId], references: [id], map: "fk_student_medical_info_school")
  studentId         String   @unique(map: "uq_student_medical_info_student") @map("student_id") @db.Uuid
  student           Student  @relation(fields: [studentId], references: [id], onDelete: Cascade, map: "fk_student_medical_info_student")
  heightCm          Decimal? @map("height_cm") @db.Decimal(5, 2)
  weightKg          Decimal? @map("weight_kg") @db.Decimal(5, 2)
  allergies         String?
  chronicConditions String?  @map("chronic_conditions")
  disabilities      String?
  emergencyNotes    String?  @map("emergency_notes")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy String?  @map("created_by") @db.Uuid
  updatedBy String?  @map("updated_by") @db.Uuid

  @@map("student_medical_info")
}

/// Student paperwork — the staff/teacher documents pattern (hard-deleted
/// with the S3 object; audit keeps history).
model StudentDocument {
  id         String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId   String              @map("school_id") @db.Uuid
  school     School              @relation(fields: [schoolId], references: [id], map: "fk_student_documents_school")
  studentId  String              @map("student_id") @db.Uuid
  student    Student             @relation(fields: [studentId], references: [id], onDelete: Cascade, map: "fk_student_documents_student")
  title      String              @db.VarChar(200)
  type       StudentDocumentType @default(OTHER)
  fileUrl    String              @map("file_url") @db.VarChar(500)
  mimeType   String              @map("mime_type") @db.VarChar(100)
  sizeBytes  Int                 @map("size_bytes")
  uploadedBy String?             @map("uploaded_by") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([studentId], map: "idx_student_documents_student")
  @@map("student_documents")
}

/// Append-only status trail (no soft delete — log table). Every
/// PUT /students/:id/status writes one row.
model StudentStatusHistory {
  id         String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  studentId  String        @map("student_id") @db.Uuid
  student    Student       @relation(fields: [studentId], references: [id], onDelete: Cascade, map: "fk_student_status_history_student")
  fromStatus StudentStatus @map("from_status")
  toStatus   StudentStatus @map("to_status")
  reason     String?
  changedBy  String?       @map("changed_by") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([studentId, createdAt], map: "idx_student_status_history_student")
  @@map("student_status_history")
}

// ── Module 10: Admission Management ───────────────────────────────────

/// One admission campaign (session-scoped, e.g. "Admission 2027"). Which
/// classes it admits — with per-class seats and application fee — lives
/// in admission_cycle_classes. Name uniqueness is a partial unique index
/// (school_id, name) WHERE deleted_at IS NULL — hand-written.
model AdmissionCycle {
  id           String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId     String               @map("school_id") @db.Uuid
  school       School               @relation(fields: [schoolId], references: [id], map: "fk_admission_cycles_school")
  sessionId    String               @map("session_id") @db.Uuid
  session      AcademicSession      @relation(fields: [sessionId], references: [id], onDelete: Cascade, map: "fk_admission_cycles_session")
  name         String               @db.VarChar(120)
  startAt      DateTime             @map("start_at") @db.Timestamptz(6)
  endAt        DateTime             @map("end_at") @db.Timestamptz(6)
  testRequired Boolean              @default(false) @map("test_required")
  status       AdmissionCycleStatus @default(DRAFT)
  /// Shown on the public application portal (eligibility, documents…).
  instructions String?

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  classes      AdmissionCycleClass[]
  applications AdmissionApplication[]
  tests        AdmissionTest[]

  @@index([schoolId, status], map: "idx_admission_cycles_school_status")
  @@index([sessionId], map: "idx_admission_cycles_session")
  @@map("admission_cycles")
}

/// Per-class admission offer inside a cycle: seats + application fee
/// (child table per roadmap M10 §3). Rows are replaced with their cycle
/// config — no soft delete (join-style table).
model AdmissionCycleClass {
  id             String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cycleId        String         @map("cycle_id") @db.Uuid
  cycle          AdmissionCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade, map: "fk_admission_cycle_classes_cycle")
  classId        String         @map("class_id") @db.Uuid
  class          SchoolClass    @relation(fields: [classId], references: [id], map: "fk_admission_cycle_classes_class")
  seats          Int
  applicationFee Decimal        @default(0) @map("application_fee") @db.Decimal(12, 2)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([cycleId, classId], map: "uq_admission_cycle_classes")
  @@index([classId], map: "idx_admission_cycle_classes_class")
  @@map("admission_cycle_classes")
}

/// An application to one class of one cycle. Applicant + guardian data
/// are SNAPSHOTS (denormalized) — the student/guardian master rows are
/// only created at conversion (POST /:id/admit), reusing the M09 dedup
/// path. application_no comes from SequenceService and is never reused.
/// Duplicate rule (M10 §6): one live application per (cycle, class,
/// phone, dob) — partial unique index, hand-written (terminal statuses
/// excluded so a CANCELLED applicant can reapply).
model AdmissionApplication {
  id            String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId      String         @map("school_id") @db.Uuid
  cycleId       String         @map("cycle_id") @db.Uuid
  cycle         AdmissionCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade, map: "fk_admission_applications_cycle")
  applicationNo String         @map("application_no") @db.VarChar(30)
  classId       String         @map("class_id") @db.Uuid
  class         SchoolClass    @relation(fields: [classId], references: [id], map: "fk_admission_applications_class")

  // ── applicant snapshot ────────────────────────────────────────────
  firstName        String   @map("first_name") @db.VarChar(100)
  lastName         String   @map("last_name") @db.VarChar(100)
  nameBn           String?  @map("name_bn") @db.VarChar(200)
  gender           Gender
  dob              DateTime @db.Date
  religion         Religion @default(ISLAM)
  /// S3 object key (uploaded pre-submit via the public photo endpoint).
  photoUrl         String?  @map("photo_url") @db.VarChar(500)
  presentAddress   Json     @default("{}") @map("present_address")
  permanentAddress Json     @default("{}") @map("permanent_address")
  previousSchool   String?  @map("previous_school") @db.VarChar(300)
  /// Kept as a real column (not only JSONB) — merit tiebreak sorts on it.
  previousGpa      Decimal? @map("previous_gpa") @db.Decimal(4, 2)
  previousResult   Json     @default("{}") @map("previous_result")
  /// Guardian snapshot: { name, nameBn?, relation, phone, email?, occupation? }
  guardian         Json     @default("{}")
  /// OTP-verified contact number (the SMS target for status updates).
  phone            String   @db.VarChar(15)

  // ── lifecycle ─────────────────────────────────────────────────────
  status            AdmissionApplicationStatus @default(SUBMITTED)
  paymentStatus     AdmissionPaymentStatus     @default(UNPAID) @map("payment_status")
  paymentRef        String?                    @map("payment_ref") @db.VarChar(100)
  paymentMethod     String?                    @map("payment_method") @db.VarChar(30)
  paidAmount        Decimal?                   @map("paid_amount") @db.Decimal(12, 2)
  paidAt            DateTime?                  @map("paid_at") @db.Timestamptz(6)
  testMarks         Decimal?                   @map("test_marks") @db.Decimal(6, 2)
  meritPosition     Int?                       @map("merit_position")
  /// Set when SELECTED (now + academic.admission_selection_deadline_days);
  /// the expiry job EXPIREs overdue selections and promotes the waitlist.
  admissionDeadline DateTime?                  @map("admission_deadline") @db.Timestamptz(6)
  /// Filled by conversion — the admitted student master record.
  studentId         String?                    @map("student_id") @db.Uuid
  student           Student?                   @relation(fields: [studentId], references: [id], map: "fk_admission_applications_student")

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  // Like other generated numbers: NOT deleted_at-scoped, never reused.
  @@unique([schoolId, applicationNo], map: "uq_admission_applications_no")
  @@index([cycleId, classId, status], map: "idx_admission_applications_cycle_class")
  @@index([schoolId, phone], map: "idx_admission_applications_phone")
  @@index([status, admissionDeadline], map: "idx_admission_applications_deadline")
  @@map("admission_applications")
}

/// Admission test slot per (cycle, class): date, venue, marks scheme.
/// Upserted wholesale by the test-scheduling endpoint.
model AdmissionTest {
  id         String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cycleId    String         @map("cycle_id") @db.Uuid
  cycle      AdmissionCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade, map: "fk_admission_tests_cycle")
  classId    String         @map("class_id") @db.Uuid
  class      SchoolClass    @relation(fields: [classId], references: [id], map: "fk_admission_tests_class")
  testDate   DateTime       @map("test_date") @db.Date
  venue      String?        @db.VarChar(200)
  totalMarks Int            @map("total_marks")
  passMarks  Int            @map("pass_marks")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy String?  @map("created_by") @db.Uuid
  updatedBy String?  @map("updated_by") @db.Uuid

  @@unique([cycleId, classId], map: "uq_admission_tests_cycle_class")
  @@map("admission_tests")
}

/// Gap-free per-school document-number sequences (PROJECT_CONTEXT §3):
/// one row per (school, prefix), bumped with SELECT … FOR UPDATE inside
/// the caller's transaction. Employee IDs first (M07); student UIDs,
/// application/invoice/voucher numbers reuse it (M09/M10/M16/M20).
model DocumentSequence {
  id        String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId  String @map("school_id") @db.Uuid
  prefix    String @db.VarChar(30)
  nextValue Int    @default(1) @map("next_value")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([schoolId, prefix], map: "uq_document_sequences_prefix")
  @@map("document_sequences")
}

// ── Module 11: Enrollment & Promotion ────────────────────────────────

/// Binds a student to a (session, class, section, group, shift) with a
/// roll number — the record every attendance/marks/fee row hangs off via
/// enrollment_id (PROJECT_CONTEXT §16), NOT student_id, so history stays
/// correct across transfers and promotions. One live enrollment per
/// student per session, and roll unique within a section — both are
/// hand-written PARTIAL unique indexes (WHERE deleted_at IS NULL AND
/// status <> 'CANCELLED'), so a CANCELLED enrollment frees the slot and
/// the roll for a re-enrollment. class_id is denormalized from the
/// section for fast roster/promotion queries.
model Enrollment {
  id                String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId          String           @map("school_id") @db.Uuid
  school            School           @relation(fields: [schoolId], references: [id], map: "fk_enrollments_school")
  studentId         String           @map("student_id") @db.Uuid
  student           Student          @relation(fields: [studentId], references: [id], onDelete: Cascade, map: "fk_enrollments_student")
  sessionId         String           @map("session_id") @db.Uuid
  session           AcademicSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade, map: "fk_enrollments_session")
  classId           String           @map("class_id") @db.Uuid
  class             SchoolClass      @relation(fields: [classId], references: [id], map: "fk_enrollments_class")
  sectionId         String           @map("section_id") @db.Uuid
  section           Section          @relation(fields: [sectionId], references: [id], onDelete: Cascade, map: "fk_enrollments_section")
  groupId           String?          @map("group_id") @db.Uuid
  group             Group?           @relation(fields: [groupId], references: [id], map: "fk_enrollments_group")
  shiftId           String?          @map("shift_id") @db.Uuid
  shift             Shift?           @relation(fields: [shiftId], references: [id], map: "fk_enrollments_shift")
  rollNo            Int              @map("roll_no")
  enrollmentDate    DateTime         @map("enrollment_date") @db.Date
  type              EnrollmentType   @default(NEW)
  status            EnrollmentStatus @default(ACTIVE)
  /// The BD "4th subject" chosen at enrollment — validated against the
  /// class's optional class_subjects for the session.
  optionalSubjectId String?          @map("optional_subject_id") @db.Uuid
  optionalSubject   Subject?         @relation("EnrollmentOptionalSubject", fields: [optionalSubjectId], references: [id], map: "fk_enrollments_optional_subject")

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  transfers       EnrollmentTransfer[]
  promotionItems  PromotionItem[]
  attendances     StudentAttendance[]
  seatPlanEntries SeatPlanEntry[]
  marks           Mark[]
  results         Result[]
  combinedResults CombinedResult[]

  // uq(student, session) and uq(session, section, roll) are hand-written
  // PARTIAL unique indexes in the migration (excluding soft-deleted +
  // CANCELLED rows) — declared here only as plain indexes for lookups.
  @@index([sessionId, sectionId, status], map: "idx_enrollments_section")
  @@index([studentId], map: "idx_enrollments_student")
  @@index([schoolId, sessionId], map: "idx_enrollments_school_session")
  @@map("enrollments")
}

/// Append-only section-transfer log (no soft delete — history table like
/// student_status_history). One row per transfer; the enrollment's
/// section_id is mutated in place. school_id is a plain column (no
/// relation), matching the audit/log-table pattern.
model EnrollmentTransfer {
  id            String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId      String     @map("school_id") @db.Uuid
  enrollmentId  String     @map("enrollment_id") @db.Uuid
  enrollment    Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade, map: "fk_enrollment_transfers_enrollment")
  fromSectionId String     @map("from_section_id") @db.Uuid
  toSectionId   String     @map("to_section_id") @db.Uuid
  fromRollNo    Int?       @map("from_roll_no")
  toRollNo      Int?       @map("to_roll_no")
  reason        String?
  transferredBy String?    @map("transferred_by") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([enrollmentId], map: "idx_enrollment_transfers_enrollment")
  @@map("enrollment_transfers")
}

/// A yearly class-promotion run (from_session → to_session). Built as a
/// DRAFT (one PromotionItem per candidate student, decision editable),
/// previewed, then EXECUTED transactionally (close old enrollments +
/// create new ones + update graduating students' status). Rollback is
/// allowed only while the new session has no dependent data (attendance/
/// marks) — status then becomes ROLLED_BACK. `criteria` records the
/// promotion inputs (pass mark, mapping) for the audit trail.
model PromotionBatch {
  id            String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId      String               @map("school_id") @db.Uuid
  school        School               @relation(fields: [schoolId], references: [id], map: "fk_promotion_batches_school")
  fromSessionId String               @map("from_session_id") @db.Uuid
  fromSession   AcademicSession      @relation("PromotionBatchFrom", fields: [fromSessionId], references: [id], onDelete: Cascade, map: "fk_promotion_batches_from_session")
  toSessionId   String               @map("to_session_id") @db.Uuid
  toSession     AcademicSession      @relation("PromotionBatchTo", fields: [toSessionId], references: [id], onDelete: Cascade, map: "fk_promotion_batches_to_session")
  status        PromotionBatchStatus @default(DRAFT)
  criteria      Json                 @default("{}")
  executedBy    String?              @map("executed_by") @db.Uuid
  executedAt    DateTime?            @map("executed_at") @db.Timestamptz(6)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy String?  @map("created_by") @db.Uuid
  updatedBy String?  @map("updated_by") @db.Uuid

  items PromotionItem[]

  @@index([schoolId, status], map: "idx_promotion_batches_school_status")
  @@map("promotion_batches")
}

/// One student's decision inside a promotion batch. `to_enrollment_id`
/// links the enrollment created at execution so rollback can delete
/// exactly those rows. result_snapshot captures the pass/fail inputs
/// (from Module 15 when available; manual before that).
model PromotionItem {
  id               String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  batchId          String            @map("batch_id") @db.Uuid
  batch            PromotionBatch    @relation(fields: [batchId], references: [id], onDelete: Cascade, map: "fk_promotion_items_batch")
  studentId        String            @map("student_id") @db.Uuid
  student          Student           @relation(fields: [studentId], references: [id], onDelete: Cascade, map: "fk_promotion_items_student")
  fromEnrollmentId String?           @map("from_enrollment_id") @db.Uuid
  fromEnrollment   Enrollment?       @relation(fields: [fromEnrollmentId], references: [id], onDelete: SetNull, map: "fk_promotion_items_from_enrollment")
  decision         PromotionDecision @default(PROMOTE)
  toClassId        String?           @map("to_class_id") @db.Uuid
  toClass          SchoolClass?      @relation(fields: [toClassId], references: [id], map: "fk_promotion_items_to_class")
  toSectionId      String?           @map("to_section_id") @db.Uuid
  toSection        Section?          @relation(fields: [toSectionId], references: [id], map: "fk_promotion_items_to_section")
  /// The enrollment created when the batch executed (for rollback).
  toEnrollmentId   String?           @map("to_enrollment_id") @db.Uuid
  resultSnapshot   Json?             @map("result_snapshot")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([batchId, studentId], map: "uq_promotion_items_student")
  @@index([batchId], map: "idx_promotion_items_batch")
  @@map("promotion_items")
}

// ── Module 12: Attendance Management ─────────────────────────────────

/// One student's attendance for one date (and one period once M13 lands;
/// period_id NULL = daily mode). Keyed on enrollment_id — never
/// student_id — so history stays correct across transfers and promotions
/// (PROJECT_CONTEXT §16). `section_id` is denormalized from the
/// enrollment AT MARKING TIME on purpose: a mid-year section transfer
/// mutates enrollments.section_id in place, and monthly registers must
/// keep showing each day under the section the student actually sat in.
/// The identity unique is a hand-written partial index over
/// (enrollment_id, date, COALESCE(period_id, nil uuid)) WHERE deleted_at
/// IS NULL — NULL periods would otherwise all be distinct.
model StudentAttendance {
  id               String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId         String           @map("school_id") @db.Uuid
  school           School           @relation(fields: [schoolId], references: [id], map: "fk_student_attendances_school")
  enrollmentId     String           @map("enrollment_id") @db.Uuid
  enrollment       Enrollment       @relation(fields: [enrollmentId], references: [id], onDelete: Cascade, map: "fk_student_attendances_enrollment")
  sectionId        String           @map("section_id") @db.Uuid
  section          Section          @relation(fields: [sectionId], references: [id], onDelete: Cascade, map: "fk_student_attendances_section")
  date             DateTime         @db.Date
  /// Timetable period (M13 — the FK is live as of that module's
  /// migration). NULL means daily-mode attendance.
  periodId         String?          @map("period_id") @db.Uuid
  period           PeriodSlot?      @relation(fields: [periodId], references: [id], onDelete: Restrict, map: "fk_student_attendances_period")
  status           AttendanceStatus
  checkInTime      DateTime?        @map("check_in_time") @db.Timestamptz(6)
  method           AttendanceMethod @default(MANUAL)
  remarks          String?
  markedBy         String?          @map("marked_by") @db.Uuid
  /// Set when the absent-SMS job notified this student's guardian —
  /// the per-student-per-day dedupe (roadmap M12 §8, SMS cost control).
  absentNotifiedAt DateTime?        @map("absent_notified_at") @db.Timestamptz(6)

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  @@index([sectionId, date], map: "idx_student_attendances_section_date")
  @@index([enrollmentId, date], map: "idx_student_attendances_enrollment_date")
  @@index([schoolId, date, status], map: "idx_student_attendances_school_date")
  @@map("student_attendances")
}

/// Daily attendance for employees. Polymorphic over teachers /
/// staff_profiles (person_type + person_id, no FK — the two lifecycles
/// stay independent, M08 decision). Identity unique
/// (person_type, person_id, date) is a partial index excluding
/// soft-deleted rows.
model StaffAttendance {
  id           String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId     String               @map("school_id") @db.Uuid
  school       School               @relation(fields: [schoolId], references: [id], map: "fk_staff_attendances_school")
  personType   AttendancePersonType @map("person_type")
  personId     String               @map("person_id") @db.Uuid
  date         DateTime             @db.Date
  status       AttendanceStatus
  checkInTime  DateTime?            @map("check_in_time") @db.Timestamptz(6)
  checkOutTime DateTime?            @map("check_out_time") @db.Timestamptz(6)
  method       AttendanceMethod     @default(MANUAL)
  remarks      String?
  markedBy     String?              @map("marked_by") @db.Uuid

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  @@index([schoolId, date], map: "idx_staff_attendances_school_date")
  @@index([personType, personId, date], map: "idx_staff_attendances_person")
  @@map("staff_attendances")
}

/// A student's leave request (raised by an admin, or by a guardian from
/// the portal in M18). Approving one retro-marks the covered dates as
/// LEAVE so an already-recorded ABSENT is corrected (roadmap M12 §6).
/// Keyed on the student (not the enrollment) — leaves are a person-level
/// fact; `session_id` scopes reporting.
model StudentLeaveApplication {
  id           String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId     String                @map("school_id") @db.Uuid
  school       School                @relation(fields: [schoolId], references: [id], map: "fk_student_leave_applications_school")
  studentId    String                @map("student_id") @db.Uuid
  student      Student               @relation(fields: [studentId], references: [id], onDelete: Cascade, map: "fk_student_leave_applications_student")
  sessionId    String                @map("session_id") @db.Uuid
  session      AcademicSession       @relation(fields: [sessionId], references: [id], onDelete: Cascade, map: "fk_student_leave_applications_session")
  fromDate     DateTime              @map("from_date") @db.Date
  toDate       DateTime              @map("to_date") @db.Date
  reason       String
  appliedBy    StudentLeaveAppliedBy @default(ADMIN) @map("applied_by")
  status       LeaveStatus           @default(PENDING)
  approvedBy   String?               @map("approved_by") @db.Uuid
  approvedAt   DateTime?             @map("approved_at") @db.Timestamptz(6)
  decisionNote String?               @map("decision_note")

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  @@index([schoolId, status], map: "idx_student_leave_applications_school_status")
  @@index([studentId, fromDate], map: "idx_student_leave_applications_student")
  @@map("student_leave_applications")
}

// ── Module 13: Timetable / Class Routine ─────────────────────────────

/// One bell-schedule row of a shift ("Period 1", 08:00–08:45). Slots are
/// per SHIFT, not per section, so the morning and day shifts each keep
/// their own bell schedule and a part-time teacher's cross-shift clash is
/// detected by comparing real times rather than slot ids (roadmap M13
/// §8). Times are TIME(0) columns like `shifts.start_time`; the service
/// compares them as minutes-of-day. Soft-deleted so a retired slot never
/// orphans the routine history that referenced it.
model PeriodSlot {
  id           String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId     String         @map("school_id") @db.Uuid
  school       School         @relation(fields: [schoolId], references: [id], map: "fk_period_slots_school")
  shiftId      String         @map("shift_id") @db.Uuid
  shift        Shift          @relation(fields: [shiftId], references: [id], map: "fk_period_slots_shift")
  name         String         @db.VarChar(50)
  startTime    DateTime       @map("start_time") @db.Time(0)
  endTime      DateTime       @map("end_time") @db.Time(0)
  type         PeriodSlotType @default(CLASS)
  displayOrder Int            @map("display_order")

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  entries            TimetableEntry[]
  studentAttendances StudentAttendance[]

  @@index([schoolId, shiftId], map: "idx_period_slots_school_shift")
  @@map("period_slots")
}

/// A section's routine for a session, versioned. At most one DRAFT and
/// one PUBLISHED per (session, section) — a hand-written partial unique
/// index over (session_id, section_id, status) WHERE deleted_at IS NULL
/// AND status <> 'ARCHIVED'. Publishing promotes the DRAFT and ARCHIVEs
/// the timetable it replaces, so `effective_from` + `version` reconstruct
/// which routine was in force on any past date (roadmap M13 §6).
model Timetable {
  id            String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId      String          @map("school_id") @db.Uuid
  school        School          @relation(fields: [schoolId], references: [id], map: "fk_timetables_school")
  sessionId     String          @map("session_id") @db.Uuid
  session       AcademicSession @relation(fields: [sessionId], references: [id], onDelete: Cascade, map: "fk_timetables_session")
  sectionId     String          @map("section_id") @db.Uuid
  section       Section         @relation(fields: [sectionId], references: [id], onDelete: Cascade, map: "fk_timetables_section")
  status        TimetableStatus @default(DRAFT)
  effectiveFrom DateTime        @map("effective_from") @db.Date
  /// 1-based, incremented per published version of the same section.
  version       Int             @default(1)
  publishedAt   DateTime?       @map("published_at") @db.Timestamptz(6)
  publishedBy   String?         @map("published_by") @db.Uuid
  notes         String?

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  entries TimetableEntry[]

  @@index([schoolId, sessionId, status], map: "idx_timetables_school_session_status")
  @@index([sectionId, status], map: "idx_timetables_section_status")
  @@map("timetables")
}

/// One cell of the routine grid: day × period → subject + teacher (+
/// room). Hard-deleted — the bulk entry endpoint replaces cells outright
/// and the audit log keeps the diff. `combined_with_section_id` is the
/// explicit combined-class marker (roadmap M13 §8): two sections sitting
/// the same lesson declare each other, and the conflict engine treats the
/// pair as one booking instead of a double-booking to be overridden away.
model TimetableEntry {
  id                    String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId              String     @map("school_id") @db.Uuid
  school                School     @relation(fields: [schoolId], references: [id], map: "fk_timetable_entries_school")
  timetableId           String     @map("timetable_id") @db.Uuid
  timetable             Timetable  @relation(fields: [timetableId], references: [id], onDelete: Cascade, map: "fk_timetable_entries_timetable")
  day                   Weekday
  periodSlotId          String     @map("period_slot_id") @db.Uuid
  periodSlot            PeriodSlot @relation(fields: [periodSlotId], references: [id], map: "fk_timetable_entries_period_slot")
  subjectId             String     @map("subject_id") @db.Uuid
  subject               Subject    @relation(fields: [subjectId], references: [id], map: "fk_timetable_entries_subject")
  teacherId             String     @map("teacher_id") @db.Uuid
  teacher               Teacher    @relation(fields: [teacherId], references: [id], map: "fk_timetable_entries_teacher")
  roomNo                String?    @map("room_no") @db.VarChar(20)
  combinedWithSectionId String?    @map("combined_with_section_id") @db.Uuid
  combinedWithSection   Section?   @relation("TimetableEntryCombinedWith", fields: [combinedWithSectionId], references: [id], map: "fk_timetable_entries_combined_section")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy String?  @map("created_by") @db.Uuid
  updatedBy String?  @map("updated_by") @db.Uuid

  @@unique([timetableId, day, periodSlotId], map: "uq_timetable_entries_cell")
  @@index([teacherId, day], map: "idx_timetable_entries_teacher_day")
  @@index([periodSlotId, day], map: "idx_timetable_entries_slot_day")
  @@map("timetable_entries")
}

// ── Module 14: Examination Management ────────────────────────────────

/// A kind of exam the school runs ("Half Yearly", "Class Test"). `weight`
/// is its share of a combined final result — Module 15 validates that the
/// weights of the set it combines add up, because only that module knows
/// which types a given report card merges (roadmap M14 §7).
model ExamType {
  id       String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId String   @map("school_id") @db.Uuid
  school   School   @relation(fields: [schoolId], references: [id], map: "fk_exam_types_school")
  name     String   @db.VarChar(100)
  /// Percentage share in a combined result; NULL = not combinable.
  weight   Decimal? @db.Decimal(5, 2)

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  exams Exam[]

  @@index([schoolId], map: "idx_exam_types_school")
  @@map("exam_types")
}

/// One exam event of a session, spanning one or more classes. The
/// grading system is referenced live while the exam is being built and
/// **frozen into `grading_snapshot` at PUBLISH** (roadmap M14 §6) so a
/// later edit to the grade bands can never restate a published result —
/// Module 15 reads the snapshot, never the live table.
model Exam {
  id              String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId        String          @map("school_id") @db.Uuid
  school          School          @relation(fields: [schoolId], references: [id], map: "fk_exams_school")
  sessionId       String          @map("session_id") @db.Uuid
  session         AcademicSession @relation(fields: [sessionId], references: [id], onDelete: Cascade, map: "fk_exams_session")
  examTypeId      String          @map("exam_type_id") @db.Uuid
  examType        ExamType        @relation(fields: [examTypeId], references: [id], map: "fk_exams_type")
  name            String          @db.VarChar(150)
  startDate       DateTime        @map("start_date") @db.Date
  endDate         DateTime        @map("end_date") @db.Date
  gradingSystemId String          @map("grading_system_id") @db.Uuid
  gradingSystem   GradingSystem   @relation(fields: [gradingSystemId], references: [id], map: "fk_exams_grading_system")
  status          ExamStatus      @default(DRAFT)
  resultPublishAt DateTime?       @map("result_publish_at") @db.Timestamptz(6)
  /// Grade bands copied verbatim at PUBLISH — the frozen scale M15 reads.
  gradingSnapshot Json?           @map("grading_snapshot")
  instructions    String?

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  examClasses  ExamClass[]
  examSubjects ExamSubject[]
  seatPlans    SeatPlan[]
  marks        Mark[]
  results      Result[]
  publications ResultPublication[]
  resultRuns   ResultRun[]

  @@index([schoolId, sessionId, status], map: "idx_exams_school_session_status")
  @@index([examTypeId], map: "idx_exams_type")
  @@map("exams")
}

/// Which classes sit an exam (join table — no soft delete). Detaching a
/// class is blocked once its subjects carry marks (Module 15).
model ExamClass {
  examId  String      @map("exam_id") @db.Uuid
  exam    Exam        @relation(fields: [examId], references: [id], onDelete: Cascade, map: "fk_exam_classes_exam")
  classId String      @map("class_id") @db.Uuid
  class   SchoolClass @relation(fields: [classId], references: [id], onDelete: Cascade, map: "fk_exam_classes_class")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@id([examId, classId], map: "pk_exam_classes")
  @@index([classId], map: "idx_exam_classes_class")
  @@map("exam_classes")
}

/// A single paper: one class × one subject of an exam, carrying both the
/// mark distribution and the sitting's schedule.
///
/// The component columns (CQ/MCQ/practical/CA) are optional — a paper
/// either has a flat `full_marks` or splits it, and when it splits the
/// parts must sum to `full_marks` (service-enforced, roadmap M14 §6). The
/// per-component `*_pass_marks` are the "per-component pass flags" of the
/// roadmap expressed as thresholds rather than booleans: non-NULL means
/// that component must be passed on its own, which is how BD boards treat
/// a practical, and a bare boolean could not carry the threshold.
///
/// Scheduling deliberately does NOT reuse M13 `period_slots`: a sitting
/// runs 2–3 hours across the bell schedule rather than inside one period,
/// so it keeps its own wall-clock `start_time` + `duration_min`. The
/// slots are still consulted to warn that a sitting collides with normal
/// classes (see ExamRoutineService).
model ExamSubject {
  id        String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId  String      @map("school_id") @db.Uuid
  school    School      @relation(fields: [schoolId], references: [id], map: "fk_exam_subjects_school")
  examId    String      @map("exam_id") @db.Uuid
  exam      Exam        @relation(fields: [examId], references: [id], onDelete: Cascade, map: "fk_exam_subjects_exam")
  classId   String      @map("class_id") @db.Uuid
  class     SchoolClass @relation(fields: [classId], references: [id], map: "fk_exam_subjects_class")
  subjectId String      @map("subject_id") @db.Uuid
  subject   Subject     @relation(fields: [subjectId], references: [id], map: "fk_exam_subjects_subject")

  fullMarks Int @map("full_marks")
  passMarks Int @map("pass_marks")

  cqMarks        Int? @map("cq_marks")
  mcqMarks       Int? @map("mcq_marks")
  practicalMarks Int? @map("practical_marks")
  caMarks        Int? @map("ca_marks")

  cqPassMarks        Int? @map("cq_pass_marks")
  mcqPassMarks       Int? @map("mcq_pass_marks")
  practicalPassMarks Int? @map("practical_pass_marks")
  caPassMarks        Int? @map("ca_pass_marks")

  /// Sitting schedule — NULL until the routine step of the wizard.
  examDate    DateTime? @map("exam_date") @db.Date
  startTime   DateTime? @map("start_time") @db.Time(0)
  durationMin Int?      @map("duration_min")
  room        String?   @db.VarChar(20)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy String?  @map("created_by") @db.Uuid
  updatedBy String?  @map("updated_by") @db.Uuid

  marks Mark[]

  @@unique([examId, classId, subjectId], map: "uq_exam_subjects_paper")
  @@index([examId, examDate], map: "idx_exam_subjects_exam_date")
  @@index([subjectId], map: "idx_exam_subjects_subject")
  @@map("exam_subjects")
}

/// One room's seating for one exam date. Generated artifacts: regenerating
/// replaces the whole date wholesale, so these are hard-deleted like M13
/// `timetable_entries` rather than soft-deleted — the audit log keeps the
/// diff and a stale half-plan would be worse than none.
model SeatPlan {
  id       String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId String           @map("school_id") @db.Uuid
  school   School           @relation(fields: [schoolId], references: [id], map: "fk_seat_plans_school")
  examId   String           @map("exam_id") @db.Uuid
  exam     Exam             @relation(fields: [examId], references: [id], onDelete: Cascade, map: "fk_seat_plans_exam")
  room     String           @db.VarChar(20)
  date     DateTime         @db.Date
  capacity Int
  strategy SeatPlanStrategy @default(SERPENTINE)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy String?  @map("created_by") @db.Uuid
  updatedBy String?  @map("updated_by") @db.Uuid

  entries SeatPlanEntry[]

  @@unique([examId, date, room], map: "uq_seat_plans_room_date")
  @@index([examId, date], map: "idx_seat_plans_exam_date")
  @@map("seat_plans")
}

/// A candidate's seat. Keyed on `enrollment_id` (the M11 canonical roster
/// handle) rather than student_id, so a mid-year section transfer cannot
/// silently re-point a seat that was allocated against the old section.
///
/// NOTE: "a candidate sits once per exam DATE" is not a DB constraint —
/// the date lives one join away on `seat_plans` and would have to be
/// denormalized to express it. The generator replaces every room of a
/// date in one transaction, so it cannot produce a cross-room duplicate;
/// the append-a-late-enrollee path checks explicitly.
model SeatPlanEntry {
  id           String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId     String     @map("school_id") @db.Uuid
  school       School     @relation(fields: [schoolId], references: [id], map: "fk_seat_plan_entries_school")
  seatPlanId   String     @map("seat_plan_id") @db.Uuid
  seatPlan     SeatPlan   @relation(fields: [seatPlanId], references: [id], onDelete: Cascade, map: "fk_seat_plan_entries_plan")
  enrollmentId String     @map("enrollment_id") @db.Uuid
  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade, map: "fk_seat_plan_entries_enrollment")
  seatNo       Int        @map("seat_no")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([seatPlanId, seatNo], map: "uq_seat_plan_entries_seat")
  @@unique([seatPlanId, enrollmentId], map: "uq_seat_plan_entries_candidate")
  @@index([enrollmentId], map: "idx_seat_plan_entries_enrollment")
  @@map("seat_plan_entries")
}

// ── Module 15: Marks & Result Processing ──────────────────────────────

/// One candidate's marks for one paper. Keyed on `enrollment_id` (the
/// M11 canonical handle), never `student_id`, so a mid-year transfer
/// cannot re-point a mark at a different section's tabulation sheet.
///
/// `total` is stored rather than derived: it is what the report card,
/// the merit list and every export read, and for a flat paper it is the
/// only number that was ever entered. For a split paper the service
/// keeps it equal to the sum of the components (a DB CHECK cannot see
/// the paper's distribution, which lives on `exam_subjects`).
///
/// `grade`/`grade_point` are NULL until a processing run computes them
/// against the exam's frozen grade scale — a mark by itself has no grade,
/// because the scale it is read through is a property of the run.
model Mark {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId      String      @map("school_id") @db.Uuid
  school        School      @relation(fields: [schoolId], references: [id], map: "fk_marks_school")
  examId        String      @map("exam_id") @db.Uuid
  exam          Exam        @relation(fields: [examId], references: [id], onDelete: Cascade, map: "fk_marks_exam")
  examSubjectId String      @map("exam_subject_id") @db.Uuid
  examSubject   ExamSubject @relation(fields: [examSubjectId], references: [id], onDelete: Cascade, map: "fk_marks_exam_subject")
  enrollmentId  String      @map("enrollment_id") @db.Uuid
  enrollment    Enrollment  @relation(fields: [enrollmentId], references: [id], onDelete: Cascade, map: "fk_marks_enrollment")

  /// Component marks — NULL on a flat paper, and on every component the
  /// paper does not allocate. Absent candidates carry all-NULL.
  cq        Decimal? @db.Decimal(6, 2)
  mcq       Decimal? @db.Decimal(6, 2)
  practical Decimal? @db.Decimal(6, 2)
  ca        Decimal? @db.Decimal(6, 2)

  total    Decimal @default(0) @db.Decimal(6, 2)
  isAbsent Boolean @default(false) @map("is_absent")

  /// Grace marks the processing run added to lift a near-miss over the
  /// pass mark (roadmap setting `exam.grace_marks`). Kept separate from
  /// `total` so the entered mark is never silently rewritten.
  graceApplied Decimal @default(0) @map("grace_applied") @db.Decimal(6, 2)

  grade      String?  @db.VarChar(5)
  gradePoint Decimal? @map("grade_point") @db.Decimal(3, 2)

  status      MarkStatus @default(DRAFT)
  enteredBy   String?    @map("entered_by") @db.Uuid
  submittedAt DateTime?  @map("submitted_at") @db.Timestamptz(6)
  verifiedBy  String?    @map("verified_by") @db.Uuid
  verifiedAt  DateTime?  @map("verified_at") @db.Timestamptz(6)
  lockedAt    DateTime?  @map("locked_at") @db.Timestamptz(6)
  remarks     String?    @db.VarChar(200)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy String?  @map("created_by") @db.Uuid
  updatedBy String?  @map("updated_by") @db.Uuid

  corrections MarkCorrection[]

  @@unique([examSubjectId, enrollmentId], map: "uq_marks_paper_candidate")
  @@index([examId, status], map: "idx_marks_exam_status")
  @@index([enrollmentId], map: "idx_marks_enrollment")
  @@map("marks")
}

/// Append-only log of every change to a LOCKED mark (roadmap M15 §4
/// re-check/correction flow). No soft delete and no updates — the whole
/// point is that a published number's history is unerasable.
model MarkCorrection {
  id       String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId String @map("school_id") @db.Uuid
  school   School @relation(fields: [schoolId], references: [id], map: "fk_mark_corrections_school")
  markId   String @map("mark_id") @db.Uuid
  mark     Mark   @relation(fields: [markId], references: [id], onDelete: Cascade, map: "fk_mark_corrections_mark")

  oldValues Json   @map("old_values")
  newValues Json   @map("new_values")
  reason    String @db.VarChar(500)

  correctedBy String   @map("corrected_by") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([markId], map: "idx_mark_corrections_mark")
  @@map("mark_corrections")
}

/// One candidate's whole-exam verdict, produced by a processing run.
///
/// `grading_snapshot` is the scale this row was graded through, copied
/// onto the row itself: editing a grade band afterwards can never
/// restate a result that has already gone home with a student (roadmap
/// M15 §8). The exam-level copy on `exams.grading_snapshot` is the same
/// blob; the per-row copy is what makes a single result self-describing
/// in an export or a re-print years later.
model Result {
  id           String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId     String     @map("school_id") @db.Uuid
  school       School     @relation(fields: [schoolId], references: [id], map: "fk_results_school")
  examId       String     @map("exam_id") @db.Uuid
  exam         Exam       @relation(fields: [examId], references: [id], onDelete: Cascade, map: "fk_results_exam")
  enrollmentId String     @map("enrollment_id") @db.Uuid
  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade, map: "fk_results_enrollment")

  totalMarks    Decimal @map("total_marks") @db.Decimal(8, 2)
  obtainedMarks Decimal @map("obtained_marks") @db.Decimal(8, 2)

  /// NCTB GPA including the 4th-subject bonus; `gpa_without_optional` is
  /// the same average with the optional subject left out entirely, which
  /// is the number boards print alongside it.
  gpa                Decimal @db.Decimal(4, 2)
  gpaWithoutOptional Decimal @map("gpa_without_optional") @db.Decimal(4, 2)
  grade              String  @db.VarChar(5)

  subjectsCount  Int          @default(0) @map("subjects_count")
  failedSubjects Int          @default(0) @map("failed_subjects")
  status         ResultStatus

  /// Competition ranking (1, 2, 2, 4) among PASSED candidates only.
  meritPositionSection Int? @map("merit_position_section")
  meritPositionClass   Int? @map("merit_position_class")

  gradingSnapshot Json      @map("grading_snapshot")
  withheldReason  String?   @map("withheld_reason") @db.VarChar(500)
  processedAt     DateTime  @default(now()) @map("processed_at") @db.Timestamptz(6)
  publishedAt     DateTime? @map("published_at") @db.Timestamptz(6)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy String?  @map("created_by") @db.Uuid
  updatedBy String?  @map("updated_by") @db.Uuid

  @@unique([examId, enrollmentId], map: "uq_results_exam_candidate")
  @@index([examId, status], map: "idx_results_exam_status")
  @@index([enrollmentId], map: "idx_results_enrollment")
  @@map("results")
}

/// A publication event. Versioned and append-only-ish: unpublishing
/// flips `is_active` rather than deleting, and republishing after a
/// correction writes version N+1 with its own changelog note. Portal and
/// public visibility read the ACTIVE publication, never `exams.status` —
/// the exam status machine deliberately cannot rewind past PUBLISHED
/// (M14), so visibility needed its own switch.
model ResultPublication {
  id       String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId String @map("school_id") @db.Uuid
  school   School @relation(fields: [schoolId], references: [id], map: "fk_result_publications_school")
  examId   String @map("exam_id") @db.Uuid
  exam     Exam   @relation(fields: [examId], references: [id], onDelete: Cascade, map: "fk_result_publications_exam")

  version     Int
  /// { portal: bool, website: bool, sms: bool } — what this version fed.
  channels    Json
  isActive    Boolean   @default(true) @map("is_active")
  note        String?   @db.VarChar(500)
  publishedBy String    @map("published_by") @db.Uuid
  publishedAt DateTime  @default(now()) @map("published_at") @db.Timestamptz(6)
  revokedBy   String?   @map("revoked_by") @db.Uuid
  revokedAt   DateTime? @map("revoked_at") @db.Timestamptz(6)

  @@unique([examId, version], map: "uq_result_publications_version")
  @@index([examId, isActive], map: "idx_result_publications_exam_active")
  @@map("result_publications")
}

/// One processing run. Progress lives here rather than only in BullMQ so
/// the status endpoint keeps answering across a Redis restart, and so a
/// run that failed halfway leaves an explainable record.
model ResultRun {
  id       String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId String @map("school_id") @db.Uuid
  school   School @relation(fields: [schoolId], references: [id], map: "fk_result_runs_school")
  examId   String @map("exam_id") @db.Uuid
  exam     Exam   @relation(fields: [examId], references: [id], onDelete: Cascade, map: "fk_result_runs_exam")

  status    ResultRunStatus @default(QUEUED)
  total     Int             @default(0)
  processed Int             @default(0)
  /// Per-candidate problems ("12 students missing Math marks") — the
  /// list the processing page renders under the progress bar.
  issues    Json?
  error     String?
  /// Ran despite unlocked papers (needs `result.process.override`).
  override  Boolean         @default(false)
  /// Re-processing a single candidate after a correction, not the exam.
  scopeEnrollmentId String? @map("scope_enrollment_id") @db.Uuid

  triggeredBy String    @map("triggered_by") @db.Uuid
  startedAt   DateTime? @map("started_at") @db.Timestamptz(6)
  finishedAt  DateTime? @map("finished_at") @db.Timestamptz(6)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([examId, createdAt], map: "idx_result_runs_exam")
  @@map("result_runs")
}

/// A weighted merge of several exams' results ("Annual = 30 % Half-Yearly
/// + 70 % Annual"). Mirrors `results` and carries the weight set it was
/// generated from, so a later change to an exam type's weight cannot
/// restate an issued final result — the same freezing argument as the
/// grading snapshot.
model CombinedResult {
  id           String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId     String          @map("school_id") @db.Uuid
  school       School          @relation(fields: [schoolId], references: [id], map: "fk_combined_results_school")
  sessionId    String          @map("session_id") @db.Uuid
  session      AcademicSession @relation(fields: [sessionId], references: [id], onDelete: Cascade, map: "fk_combined_results_session")
  enrollmentId String          @map("enrollment_id") @db.Uuid
  enrollment   Enrollment      @relation(fields: [enrollmentId], references: [id], onDelete: Cascade, map: "fk_combined_results_enrollment")

  /// Names the merge ("Final Result 2026") — the handle a report card asks for.
  name String @db.VarChar(150)
  /// [{ examId, examName, weight, gpa, obtainedMarks }] frozen at generation.
  components Json
  /// { examId: weight } — the weight set, summing to 100.
  weights    Json

  totalMarks    Decimal      @map("total_marks") @db.Decimal(8, 2)
  obtainedMarks Decimal      @map("obtained_marks") @db.Decimal(8, 2)
  gpa           Decimal      @db.Decimal(4, 2)
  grade         String       @db.VarChar(5)
  status        ResultStatus

  meritPositionSection Int? @map("merit_position_section")
  meritPositionClass   Int? @map("merit_position_class")

  generatedAt DateTime @default(now()) @map("generated_at") @db.Timestamptz(6)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy   String?  @map("created_by") @db.Uuid
  updatedBy   String?  @map("updated_by") @db.Uuid

  @@unique([sessionId, name, enrollmentId], map: "uq_combined_results_candidate")
  @@index([sessionId, name], map: "idx_combined_results_batch")
  @@index([enrollmentId], map: "idx_combined_results_enrollment")
  @@map("combined_results")
}

// ── Module 03: Authorization, Roles & Audit Logging ──────────────────

/// Granular permission catalog, synced from the TS code registry
/// (src/modules/rbac/registry/permission.registry.ts — the source of
/// truth). Global, not school-scoped: schools share one catalog and
/// differ only in role→permission mappings. `is_orphaned` flags codes
/// that were removed from the registry but are still referenced by
/// roles — the guard ignores them (roadmap M03 §8).
model Permission {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code        String  @unique(map: "uq_permissions_code") @db.VarChar(100)
  module      String  @db.VarChar(50)
  description String?
  isOrphaned  Boolean @default(false) @map("is_orphaned")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  rolePermissions RolePermission[]

  @@map("permissions")
}

/// RBAC role. System roles (is_system) are seeded, cannot be deleted or
/// renamed, and their seeded core permissions are locked (extend-only).
/// Slug uniqueness is a partial unique index (school_id, slug) WHERE
/// deleted_at IS NULL — hand-written in the migration SQL.
model Role {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId    String  @map("school_id") @db.Uuid
  school      School  @relation(fields: [schoolId], references: [id], map: "fk_roles_school")
  name        String  @db.VarChar(64)
  slug        String  @db.VarChar(64)
  description String?
  isSystem    Boolean @default(false) @map("is_system")

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  rolePermissions RolePermission[]
  userRoles       UserRole[]

  @@index([schoolId], map: "idx_roles_school")
  @@map("roles")
}

/// Role → permission grant (join table: no soft delete per conventions).
model RolePermission {
  roleId       String     @map("role_id") @db.Uuid
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade, map: "fk_role_permissions_role")
  permissionId String     @map("permission_id") @db.Uuid
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade, map: "fk_role_permissions_permission")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@id([roleId, permissionId], map: "pk_role_permissions")
  @@index([permissionId], map: "idx_role_permissions_permission")
  @@map("role_permissions")
}

/// User → role assignment (join table). Who assigned what is captured in
/// audit_logs, not here.
model UserRole {
  userId String @map("user_id") @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade, map: "fk_user_roles_user")
  roleId String @map("role_id") @db.Uuid
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade, map: "fk_user_roles_role")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@id([userId, roleId], map: "pk_user_roles")
  @@index([roleId], map: "idx_user_roles_role")
  @@map("user_roles")
}

/// Immutable audit trail written by the global AuditInterceptor on every
/// mutating request (global business rule §11 — no update/delete API).
/// BIGSERIAL id + no FK to users: partition-ready for monthly partitions
/// and a retention policy in Module 30. `action` is VARCHAR, not a PG
/// enum — the verb set grows per module (CREATE|UPDATE|DELETE|LOGIN|
/// EXPORT|…) without needing enum migrations.
model AuditLog {
  id         BigInt  @id @default(autoincrement())
  schoolId   String  @map("school_id") @db.Uuid
  userId     String? @map("user_id") @db.Uuid
  action     String  @db.VarChar(32)
  entityType String  @map("entity_type") @db.VarChar(64)
  entityId   String? @map("entity_id") @db.VarChar(64)
  oldValues  Json?   @map("old_values")
  newValues  Json?   @map("new_values")
  ip         String? @db.VarChar(64)
  userAgent  String? @map("user_agent") @db.VarChar(512)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([schoolId, entityType, entityId], map: "idx_audit_logs_entity")
  @@index([userId, createdAt], map: "idx_audit_logs_user_created")
  @@map("audit_logs")
}

/// Append-only security log (global business rule §11) — no updates, no
/// soft delete. Written by event listeners only.
model LoginActivity {
  id        String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String     @map("user_id") @db.Uuid
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade, map: "fk_login_activities_user")
  event     LoginEvent
  ip        String?    @db.VarChar(64)
  userAgent String?    @map("user_agent") @db.VarChar(512)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([userId, createdAt], map: "idx_login_activities_user_created")
  @@map("login_activities")
}
