// HexSchool SMIS — Prisma schema (ORM decision revised in Module 02:
// Prisma replaces TypeORM — see PROJECT_CONTEXT.md §16).
//
// Global conventions (SMIS_DEVELOPMENT_ROADMAP):
//   - snake_case plural tables via @@map, snake_case columns via @map
//   - UUID PKs via gen_random_uuid() (pgcrypto)
//   - audit fields + soft delete (deleted_at) on business entities
//   - every business table carries school_id (Module 31 readiness)
//   - constraint prefixes fk_/uq_/idx_/chk_ (CHECKs + partial unique
//     indexes are hand-written in migration SQL — Prisma can't express them)

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [pgcrypto, citext]
}

// ── Enums (PG native, names locked by @@map) ──────────────────────────

enum UserType {
  SUPER_ADMIN
  ADMIN
  STAFF
  TEACHER
  STUDENT
  PARENT

  @@map("user_type_enum")
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING

  @@map("user_status_enum")
}

enum OtpPurpose {
  PASSWORD_RESET
  LOGIN_2FA
  PHONE_VERIFY
  EMAIL_VERIFY
  ADMISSION

  @@map("otp_purpose_enum")
}

enum LoginEvent {
  LOGIN_SUCCESS
  LOGIN_FAILED
  LOGOUT
  REFRESH
  PASSWORD_CHANGED
  LOCKED
  TOKEN_REUSE

  @@map("login_event_enum")
}

enum SchoolType {
  PRIMARY
  HIGH_SCHOOL
  KINDERGARTEN
  ENGLISH_VERSION
  ENGLISH_MEDIUM
  MADRASA
  VOCATIONAL
  COLLEGE

  @@map("school_type_enum")
}

enum SchoolStatus {
  ACTIVE
  INACTIVE
  SUSPENDED

  @@map("school_status_enum")
}

enum SettingsGroup {
  general
  academic
  sms
  email
  payment
  attendance
  exam
  fees

  @@map("settings_group_enum")
}

enum SubjectType {
  THEORY
  PRACTICAL
  BOTH

  @@map("subject_type_enum")
}

enum SessionStatus {
  UPCOMING
  ACTIVE
  COMPLETED
  ARCHIVED

  @@map("session_status_enum")
}

enum HolidayType {
  GOVERNMENT
  RELIGIOUS
  SCHOOL
  WEEKLY

  @@map("holiday_type_enum")
}

enum HolidayAppliesTo {
  ALL
  STUDENTS
  STAFF

  @@map("holiday_applies_to_enum")
}

enum CalendarEventType {
  EXAM
  EVENT
  MEETING
  SPORTS
  CULTURAL
  OTHER

  @@map("calendar_event_type_enum")
}

// ── Module 02: Authentication ─────────────────────────────────────────

/// Central account record for every human in the system. Role-specific
/// profile tables (Modules 07–09) link back 1:1. Uniqueness of email/phone
/// is enforced by partial unique indexes (WHERE deleted_at IS NULL) plus
/// chk_users_contact (email OR phone) — see the migration SQL.
/// school_id has no FK until Module 04 creates `schools`.
model User {
  id                  String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId            String     @map("school_id") @db.Uuid
  school              School     @relation(fields: [schoolId], references: [id], map: "fk_users_school")
  email               String?    @db.Citext
  phone               String?    @db.VarChar(15)
  passwordHash        String     @map("password_hash")
  userType            UserType   @map("user_type")
  status              UserStatus @default(ACTIVE)
  lastLoginAt         DateTime?  @map("last_login_at") @db.Timestamptz(6)
  passwordChangedAt   DateTime?  @map("password_changed_at") @db.Timestamptz(6)
  failedLoginAttempts Int        @default(0) @map("failed_login_attempts")
  lockedUntil         DateTime?  @map("locked_until") @db.Timestamptz(6)
  mustChangePassword  Boolean    @default(false) @map("must_change_password")

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  refreshTokens   RefreshToken[]
  otpCodes        OtpCode[]
  loginActivities LoginActivity[]
  userRoles       UserRole[]

  @@map("users")
}

/// One row per issued refresh token (multi-device sessions). Only the
/// SHA-256 hash is stored — the plaintext lives in the httpOnly cookie.
/// Rotation links old → new via replaced_by_id; a revoked token presented
/// again outside the race-grace window means theft. Purged nightly.
model RefreshToken {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade, map: "fk_refresh_tokens_user")
  tokenHash    String    @unique(map: "uq_refresh_tokens_token_hash") @map("token_hash") @db.VarChar(64)
  deviceInfo   Json      @default("{}") @map("device_info")
  expiresAt    DateTime  @map("expires_at") @db.Timestamptz(6)
  revokedAt    DateTime? @map("revoked_at") @db.Timestamptz(6)
  replacedById String?   @map("replaced_by_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([userId], map: "idx_refresh_tokens_user_id")
  @@map("refresh_tokens")
}

/// Hashed one-time codes (password reset, verification, admission…).
/// user_id is nullable: admission applicants (Module 10) verify phones
/// before having an account. Limits enforced in OtpService.
model OtpCode {
  id         String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String?    @map("user_id") @db.Uuid
  user       User?      @relation(fields: [userId], references: [id], onDelete: SetNull, map: "fk_otp_codes_user")
  identifier String
  codeHash   String     @map("code_hash") @db.VarChar(64)
  purpose    OtpPurpose
  expiresAt  DateTime   @map("expires_at") @db.Timestamptz(6)
  consumedAt DateTime?  @map("consumed_at") @db.Timestamptz(6)
  attempts   Int        @default(0)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([identifier, purpose, createdAt], map: "idx_otp_codes_identifier")
  @@map("otp_codes")
}

// ── Module 04: School Setup & Settings ────────────────────────────────

/// The tenant root — every business table's school_id points here since
/// M04 (users/roles carried the column FK-less from M02/03; this module
/// adds the constraints). Single row today; Module 31 turns this into
/// the multi-school catalog. The migration inserts the bootstrap row
/// with the fixed DEFAULT_SCHOOL_ID before wiring the FKs.
model School {
  id              String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String       @db.VarChar(200)
  nameBn          String?      @map("name_bn") @db.VarChar(200)
  /// Short unique code used in generated document numbers (M07+).
  code            String       @db.VarChar(10)
  /// BD Education Board EIIN (6 digits) — nullable for kindergartens etc.
  eiinNumber      String?      @map("eiin_number") @db.VarChar(6)
  type            SchoolType   @default(HIGH_SCHOOL)
  address         String?
  phone           String?      @db.VarChar(20)
  email           String?      @db.Citext
  website         String?      @db.VarChar(200)
  logoUrl         String?      @map("logo_url") @db.VarChar(500)
  establishedYear Int?         @map("established_year")
  principalName   String?      @map("principal_name") @db.VarChar(120)
  status          SchoolStatus @default(ACTIVE)

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  users            User[]
  roles            Role[]
  settings         SchoolSetting[]
  gradingSystems   GradingSystem[]
  academicSessions AcademicSession[]
  departments      Department[]
  shifts           Shift[]
  classes          SchoolClass[]
  groups           Group[]
  sections         Section[]
  subjects         Subject[]
  classSubjects    ClassSubject[]

  @@map("schools")
}

/// Generic key-value configuration, one row per key. Keys/types/secrecy
/// are declared in the TS settings registry (settings.registry.ts);
/// secret values are AES-256-GCM encrypted before they land here.
model SchoolSetting {
  id       String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId String        @map("school_id") @db.Uuid
  school   School        @relation(fields: [schoolId], references: [id], onDelete: Cascade, map: "fk_school_settings_school")
  key      String        @db.VarChar(100)
  value    Json
  group    SettingsGroup

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  updatedBy String?  @map("updated_by") @db.Uuid

  @@unique([schoolId, key], map: "uq_school_settings_key")
  @@index([schoolId, group], map: "idx_school_settings_group")
  @@map("school_settings")
}

/// Grade scale container. Exactly one default per school (partial unique
/// index, hand-written); a system may only become default once its grade
/// ranges cover 0–100 with no gaps/overlaps (service-enforced).
model GradingSystem {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId  String  @map("school_id") @db.Uuid
  school    School  @relation(fields: [schoolId], references: [id], onDelete: Cascade, map: "fk_grading_systems_school")
  name      String  @db.VarChar(100)
  isDefault Boolean @default(false) @map("is_default")

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  gradePoints GradePoint[]

  @@index([schoolId], map: "idx_grading_systems_school")
  @@map("grading_systems")
}

/// One grade band (A+ 80–100 → 5.00). Child rows are replaced wholesale
/// with their system — no soft delete. Range sanity (min ≤ max) is a DB
/// CHECK; non-overlap is service-enforced.
model GradePoint {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gradingSystemId String        @map("grading_system_id") @db.Uuid
  gradingSystem   GradingSystem @relation(fields: [gradingSystemId], references: [id], onDelete: Cascade, map: "fk_grade_points_system")
  grade           String        @db.VarChar(5)
  point           Decimal       @db.Decimal(3, 2)
  minMark         Int           @map("min_mark")
  maxMark         Int           @map("max_mark")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([gradingSystemId, grade], map: "uq_grade_points_grade")
  @@map("grade_points")
}

// ── Module 05: Academic Session & Calendar ────────────────────────────

/// Academic year — the temporal backbone every enrollment/attendance/
/// exam/fee record scopes to (from M11 on). Exactly one is_current per
/// school (partial unique index, hand-written); date ranges of a
/// school's sessions never overlap (service-enforced); COMPLETED
/// sessions become read-only for entry flows (enforced by consumers).
model AcademicSession {
  id        String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId  String        @map("school_id") @db.Uuid
  school    School        @relation(fields: [schoolId], references: [id], map: "fk_academic_sessions_school")
  name      String        @db.VarChar(50)
  startDate DateTime      @map("start_date") @db.Date
  endDate   DateTime      @map("end_date") @db.Date
  status    SessionStatus @default(UPCOMING)
  isCurrent Boolean       @default(false) @map("is_current")

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  holidays       Holiday[]
  calendarEvents CalendarEvent[]
  sections       Section[]
  classSubjects  ClassSubject[]

  @@index([schoolId], map: "idx_academic_sessions_school")
  @@map("academic_sessions")
}

/// Non-working day range. Hard-deleted (spec: audit only, no soft
/// delete) — cancelling a holiday removes it; the audit trail keeps the
/// history. WEEKLY rows are ad-hoc extras; the recurring weekly holiday
/// comes from the `general.weekly_holidays` setting (M04).
model Holiday {
  id        String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId  String           @map("school_id") @db.Uuid
  sessionId String           @map("session_id") @db.Uuid
  session   AcademicSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade, map: "fk_holidays_session")
  title     String           @db.VarChar(200)
  startDate DateTime         @map("start_date") @db.Date
  endDate   DateTime         @map("end_date") @db.Date
  type      HolidayType      @default(SCHOOL)
  appliesTo HolidayAppliesTo @default(ALL) @map("applies_to")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy String?  @map("created_by") @db.Uuid
  updatedBy String?  @map("updated_by") @db.Uuid

  @@index([schoolId, startDate, endDate], map: "idx_holidays_range")
  @@index([sessionId], map: "idx_holidays_session")
  @@map("holidays")
}

/// Calendar entry (exam window, meeting, sports day…). is_public rows
/// surface on the public website (M19).
model CalendarEvent {
  id          String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId    String            @map("school_id") @db.Uuid
  sessionId   String            @map("session_id") @db.Uuid
  session     AcademicSession   @relation(fields: [sessionId], references: [id], onDelete: Cascade, map: "fk_calendar_events_session")
  title       String            @db.VarChar(200)
  description String?
  startDate   DateTime          @map("start_date") @db.Date
  endDate     DateTime          @map("end_date") @db.Date
  type        CalendarEventType @default(EVENT)
  isPublic    Boolean           @default(false) @map("is_public")

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  @@index([schoolId, startDate, endDate], map: "idx_calendar_events_range")
  @@index([sessionId], map: "idx_calendar_events_session")
  @@map("calendar_events")
}

// ── Module 06: Academic Structure ─────────────────────────────────────

/// Organizational unit for staff (M07) and subjects.
model Department {
  id       String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId String @map("school_id") @db.Uuid
  school   School @relation(fields: [schoolId], references: [id], map: "fk_departments_school")
  name     String @db.VarChar(100)
  code     String @db.VarChar(20)

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  subjects Subject[]

  @@index([schoolId], map: "idx_departments_school")
  @@map("departments")
}

/// School shift (Morning/Day). Rarely churns — hard-deleted (spec:
/// audit only), delete guarded while sections reference it.
model Shift {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId  String   @map("school_id") @db.Uuid
  school    School   @relation(fields: [schoolId], references: [id], map: "fk_shifts_school")
  name      String   @db.VarChar(50)
  startTime DateTime @map("start_time") @db.Time(0)
  endTime   DateTime @map("end_time") @db.Time(0)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy String?  @map("created_by") @db.Uuid
  updatedBy String?  @map("updated_by") @db.Uuid

  sections Section[]

  @@index([schoolId], map: "idx_shifts_school")
  @@map("shifts")
}

/// Session-independent class master ("Class 6"). numeric_level drives
/// ordering and the group-applicability rule; free-form names support
/// Madrasa/Vocational naming (M06 §8). Model named SchoolClass because
/// `class` collides with the TS keyword in generated code.
model SchoolClass {
  id           String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId     String  @map("school_id") @db.Uuid
  school       School  @relation(fields: [schoolId], references: [id], map: "fk_classes_school")
  name         String  @db.VarChar(100)
  nameBn       String? @map("name_bn") @db.VarChar(100)
  numericLevel Int     @map("numeric_level")
  displayOrder Int     @default(0) @map("display_order")

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  sections      Section[]
  classSubjects ClassSubject[]

  @@index([schoolId], map: "idx_classes_school")
  @@map("classes")
}

/// Academic stream (Science/Commerce/Arts/…). Applies only from a class
/// level (BD default: class 9) — enforced when a section/mapping uses it.
model Group {
  id                  String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId            String @map("school_id") @db.Uuid
  school              School @relation(fields: [schoolId], references: [id], map: "fk_groups_school")
  name                String @db.VarChar(50)
  applicableFromLevel Int    @default(9) @map("applicable_from_level")

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  sections      Section[]
  classSubjects ClassSubject[]

  @@index([schoolId], map: "idx_groups_school")
  @@map("groups")
}

/// Where a student sits: session-scoped (Class 6-A of 2026 ≠ 2027).
/// Identity uniqueness (school, session, class, name, shift) is a
/// hand-written COALESCE index (NULL shift must not evade it).
/// class_teacher_id has NO FK until Module 08 creates `teachers`.
model Section {
  id             String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId       String          @map("school_id") @db.Uuid
  school         School          @relation(fields: [schoolId], references: [id], map: "fk_sections_school")
  classId        String          @map("class_id") @db.Uuid
  class          SchoolClass     @relation(fields: [classId], references: [id], map: "fk_sections_class")
  sessionId      String          @map("session_id") @db.Uuid
  session        AcademicSession @relation(fields: [sessionId], references: [id], onDelete: Cascade, map: "fk_sections_session")
  name           String          @db.VarChar(5)
  shiftId        String?         @map("shift_id") @db.Uuid
  shift          Shift?          @relation(fields: [shiftId], references: [id], map: "fk_sections_shift")
  groupId        String?         @map("group_id") @db.Uuid
  group          Group?          @relation(fields: [groupId], references: [id], map: "fk_sections_group")
  /// Advisory at creation; enforced at enrollment (M11) with override.
  capacity       Int?
  classTeacherId String?         @map("class_teacher_id") @db.Uuid
  roomNo         String?         @map("room_no") @db.VarChar(20)

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  @@index([schoolId, sessionId], map: "idx_sections_school_session")
  @@index([classId], map: "idx_sections_class")
  @@map("sections")
}

/// Session-independent subject master. THEORY/PRACTICAL split marks are
/// handled by `type` + exam mark distribution (M14), never duplicates.
model Subject {
  id           String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId     String      @map("school_id") @db.Uuid
  school       School      @relation(fields: [schoolId], references: [id], map: "fk_subjects_school")
  name         String      @db.VarChar(100)
  nameBn       String?     @map("name_bn") @db.VarChar(100)
  code         String      @db.VarChar(20)
  departmentId String?     @map("department_id") @db.Uuid
  department   Department? @relation(fields: [departmentId], references: [id], map: "fk_subjects_department")
  type         SubjectType @default(THEORY)

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  classSubjects ClassSubject[]

  @@index([schoolId], map: "idx_subjects_school")
  @@map("subjects")
}

/// Curriculum mapping: what a class studies in a session (optionally per
/// group; is_optional marks the BD "4th subject"). Rows are replaced by
/// the bulk assign endpoint; removal is blocked once marks exist (M15
/// extends the guard). Identity uniqueness is a COALESCE index (NULL
/// group must not evade it).
model ClassSubject {
  id               String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId         String          @map("school_id") @db.Uuid
  school           School          @relation(fields: [schoolId], references: [id], map: "fk_class_subjects_school")
  classId          String          @map("class_id") @db.Uuid
  class            SchoolClass     @relation(fields: [classId], references: [id], map: "fk_class_subjects_class")
  subjectId        String          @map("subject_id") @db.Uuid
  subject          Subject         @relation(fields: [subjectId], references: [id], map: "fk_class_subjects_subject")
  sessionId        String          @map("session_id") @db.Uuid
  session          AcademicSession @relation(fields: [sessionId], references: [id], onDelete: Cascade, map: "fk_class_subjects_session")
  groupId          String?         @map("group_id") @db.Uuid
  group            Group?          @relation(fields: [groupId], references: [id], map: "fk_class_subjects_group")
  isOptional       Boolean         @default(false) @map("is_optional")
  fullMarksDefault Int             @default(100) @map("full_marks_default")
  displayOrder     Int             @default(0) @map("display_order")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([classId, sessionId], map: "idx_class_subjects_class_session")
  @@index([subjectId], map: "idx_class_subjects_subject")
  @@map("class_subjects")
}

// ── Module 03: Authorization, Roles & Audit Logging ──────────────────

/// Granular permission catalog, synced from the TS code registry
/// (src/modules/rbac/registry/permission.registry.ts — the source of
/// truth). Global, not school-scoped: schools share one catalog and
/// differ only in role→permission mappings. `is_orphaned` flags codes
/// that were removed from the registry but are still referenced by
/// roles — the guard ignores them (roadmap M03 §8).
model Permission {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code        String  @unique(map: "uq_permissions_code") @db.VarChar(100)
  module      String  @db.VarChar(50)
  description String?
  isOrphaned  Boolean @default(false) @map("is_orphaned")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  rolePermissions RolePermission[]

  @@map("permissions")
}

/// RBAC role. System roles (is_system) are seeded, cannot be deleted or
/// renamed, and their seeded core permissions are locked (extend-only).
/// Slug uniqueness is a partial unique index (school_id, slug) WHERE
/// deleted_at IS NULL — hand-written in the migration SQL.
model Role {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId    String  @map("school_id") @db.Uuid
  school      School  @relation(fields: [schoolId], references: [id], map: "fk_roles_school")
  name        String  @db.VarChar(64)
  slug        String  @db.VarChar(64)
  description String?
  isSystem    Boolean @default(false) @map("is_system")

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  rolePermissions RolePermission[]
  userRoles       UserRole[]

  @@index([schoolId], map: "idx_roles_school")
  @@map("roles")
}

/// Role → permission grant (join table: no soft delete per conventions).
model RolePermission {
  roleId       String     @map("role_id") @db.Uuid
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade, map: "fk_role_permissions_role")
  permissionId String     @map("permission_id") @db.Uuid
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade, map: "fk_role_permissions_permission")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@id([roleId, permissionId], map: "pk_role_permissions")
  @@index([permissionId], map: "idx_role_permissions_permission")
  @@map("role_permissions")
}

/// User → role assignment (join table). Who assigned what is captured in
/// audit_logs, not here.
model UserRole {
  userId String @map("user_id") @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade, map: "fk_user_roles_user")
  roleId String @map("role_id") @db.Uuid
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade, map: "fk_user_roles_role")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@id([userId, roleId], map: "pk_user_roles")
  @@index([roleId], map: "idx_user_roles_role")
  @@map("user_roles")
}

/// Immutable audit trail written by the global AuditInterceptor on every
/// mutating request (global business rule §11 — no update/delete API).
/// BIGSERIAL id + no FK to users: partition-ready for monthly partitions
/// and a retention policy in Module 30. `action` is VARCHAR, not a PG
/// enum — the verb set grows per module (CREATE|UPDATE|DELETE|LOGIN|
/// EXPORT|…) without needing enum migrations.
model AuditLog {
  id         BigInt  @id @default(autoincrement())
  schoolId   String  @map("school_id") @db.Uuid
  userId     String? @map("user_id") @db.Uuid
  action     String  @db.VarChar(32)
  entityType String  @map("entity_type") @db.VarChar(64)
  entityId   String? @map("entity_id") @db.VarChar(64)
  oldValues  Json?   @map("old_values")
  newValues  Json?   @map("new_values")
  ip         String? @db.VarChar(64)
  userAgent  String? @map("user_agent") @db.VarChar(512)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([schoolId, entityType, entityId], map: "idx_audit_logs_entity")
  @@index([userId, createdAt], map: "idx_audit_logs_user_created")
  @@map("audit_logs")
}

/// Append-only security log (global business rule §11) — no updates, no
/// soft delete. Written by event listeners only.
model LoginActivity {
  id        String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String     @map("user_id") @db.Uuid
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade, map: "fk_login_activities_user")
  event     LoginEvent
  ip        String?    @db.VarChar(64)
  userAgent String?    @map("user_agent") @db.VarChar(512)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([userId, createdAt], map: "idx_login_activities_user_created")
  @@map("login_activities")
}
